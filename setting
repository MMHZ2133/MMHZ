<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>__USER_NAME__ - Gaming Portal</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800;900&family=Exo+2:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        /* ===== RESET & BASE ===== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Exo 2', 'Orbitron', sans-serif;
            background: #0a0a0a;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
            overflow-x: hidden;
            color: #fff;
        }

        /* ===== GAMING ANIMATED BACKGROUND ===== */
        .gaming-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            background: #0a0a0a;
            overflow: hidden;
        }

        .gaming-bg::before {
            content: '';
            position: absolute;
            width: 300%;
            height: 300%;
            top: -100%;
            left: -100%;
            background: 
                radial-gradient(circle at 20% 50%, rgba(255,0,255,0.1), transparent 50%),
                radial-gradient(circle at 80% 50%, rgba(0,255,255,0.1), transparent 50%),
                radial-gradient(circle at 50% 20%, rgba(255,100,0,0.08), transparent 50%),
                radial-gradient(circle at 50% 80%, rgba(0,255,100,0.08), transparent 50%);
            animation: bgPulse 8s ease-in-out infinite alternate;
        }

        @keyframes bgPulse {
            0% { opacity: 0.5; transform: scale(1); }
            100% { opacity: 1; transform: scale(1.2); }
        }

        .gaming-bg::after {
            content: '';
            position: absolute;
            width: 100%;
            height: 100%;
            background: 
                repeating-linear-gradient(0deg, transparent, transparent 50px, rgba(255,255,255,0.01) 50px, rgba(255,255,255,0.01) 51px),
                repeating-linear-gradient(90deg, transparent, transparent 50px, rgba(255,255,255,0.01) 50px, rgba(255,255,255,0.01) 51px);
            animation: gridMove 10s linear infinite;
        }

        @keyframes gridMove {
            0% { transform: translate(0, 0); }
            100% { transform: translate(50px, 50px); }
        }

        /* ===== GLOW PARTICLES ===== */
        .particles {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            pointer-events: none;
            overflow: hidden;
        }

        .particle {
            position: absolute;
            width: 2px;
            height: 2px;
            background: rgba(255,255,255,0.3);
            border-radius: 50%;
            animation: floatParticle linear infinite;
        }

        @keyframes floatParticle {
            0% { transform: translateY(100vh) scale(0); opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { transform: translateY(-10vh) scale(1); opacity: 0; }
        }

        /* ===== MAIN CONTAINER ===== */
        .gaming-container {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 1200px;
        }

        /* ===== GLOW CARD ===== */
        .gaming-card {
            background: rgba(10, 10, 10, 0.85);
            backdrop-filter: blur(20px);
            border: 2px solid transparent;
            border-radius: 24px;
            padding: 30px;
            box-shadow: 0 0 60px rgba(255, 0, 255, 0.1), 0 0 120px rgba(0, 255, 255, 0.05);
            animation: borderGlow 4s ease-in-out infinite alternate;
            transition: all 0.3s;
        }

        .gaming-card:hover {
            box-shadow: 0 0 80px rgba(255, 0, 255, 0.2), 0 0 160px rgba(0, 255, 255, 0.1);
        }

        @keyframes borderGlow {
            0% { border-color: #ff00ff66; box-shadow: 0 0 60px rgba(255,0,255,0.1); }
            25% { border-color: #00ffff66; box-shadow: 0 0 60px rgba(0,255,255,0.1); }
            50% { border-color: #ff660066; box-shadow: 0 0 60px rgba(255,102,0,0.1); }
            75% { border-color: #00ff6666; box-shadow: 0 0 60px rgba(0,255,102,0.1); }
            100% { border-color: #ff00ff66; box-shadow: 0 0 60px rgba(255,0,255,0.1); }
        }

        /* ===== PROFILE AVATAR ===== */
        .gaming-avatar {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: linear-gradient(135deg, #ff00ff, #00ffff);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 36px;
            font-weight: 900;
            color: #fff;
            box-shadow: 0 0 40px rgba(255, 0, 255, 0.3);
            animation: avatarPulse 2s ease-in-out infinite alternate;
            margin: 0 auto 15px;
            border: 3px solid rgba(255,255,255,0.1);
        }

        @keyframes avatarPulse {
            0% { box-shadow: 0 0 40px rgba(255, 0, 255, 0.3); }
            100% { box-shadow: 0 0 80px rgba(0, 255, 255, 0.4); }
        }

        /* ===== GAMING TYPOGRAPHY ===== */
        .gaming-title {
            font-family: 'Orbitron', sans-serif;
            font-weight: 900;
            text-align: center;
            background: linear-gradient(90deg, #ff00ff, #00ffff, #ff6600, #ff00ff);
            background-size: 300% 100%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: gradientMove 3s linear infinite;
            letter-spacing: 2px;
        }

        @keyframes gradientMove {
            0% { background-position: 0% 50%; }
            100% { background-position: 300% 50%; }
        }

        .gaming-subtitle {
            text-align: center;
            color: rgba(255,255,255,0.3);
            font-size: 14px;
            letter-spacing: 4px;
            text-transform: uppercase;
            font-family: 'Orbitron', sans-serif;
        }

        .gaming-label {
            font-family: 'Orbitron', sans-serif;
            font-size: 10px;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: rgba(255,255,255,0.4);
        }

        /* ===== STATUS BADGE ===== */
        .gaming-badge {
            display: inline-block;
            padding: 6px 20px;
            border-radius: 20px;
            font-family: 'Orbitron', sans-serif;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            border: 1px solid;
            animation: badgePulse 2s ease-in-out infinite;
        }

        .gaming-badge.active {
            background: rgba(0, 255, 100, 0.15);
            border-color: #00ff64;
            color: #00ff64;
            box-shadow: 0 0 30px rgba(0, 255, 100, 0.1);
        }

        .gaming-badge.paused {
            background: rgba(255, 165, 0, 0.15);
            border-color: #ffa500;
            color: #ffa500;
            box-shadow: 0 0 30px rgba(255, 165, 0, 0.1);
        }

        .gaming-badge.expired {
            background: rgba(255, 0, 0, 0.15);
            border-color: #ff4444;
            color: #ff4444;
            box-shadow: 0 0 30px rgba(255, 0, 0, 0.1);
        }

        .gaming-badge.limit {
            background: rgba(255, 0, 0, 0.15);
            border-color: #ff4444;
            color: #ff4444;
            box-shadow: 0 0 30px rgba(255, 0, 0, 0.1);
        }

        .gaming-badge.dailyLimit {
            background: rgba(255, 165, 0, 0.15);
            border-color: #ffa500;
            color: #ffa500;
            box-shadow: 0 0 30px rgba(255, 165, 0, 0.1);
        }

        @keyframes badgePulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.7; }
        }

        /* ===== STAT NUMBERS ===== */
        .gaming-stat {
            font-family: 'Orbitron', sans-serif;
            font-weight: 900;
            font-size: 28px;
            background: linear-gradient(90deg, #fff, #a78bfa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .gaming-stat-small {
            font-family: 'Orbitron', sans-serif;
            font-weight: 600;
            font-size: 14px;
            color: rgba(255,255,255,0.4);
        }

        /* ===== PROGRESS BAR ===== */
        .gaming-progress {
            width: 100%;
            height: 6px;
            background: rgba(255,255,255,0.05);
            border-radius: 10px;
            overflow: hidden;
            margin-top: 8px;
        }

        .gaming-progress-fill {
            height: 100%;
            border-radius: 10px;
            background: linear-gradient(90deg, #ff00ff, #00ffff, #ff6600);
            background-size: 200% 100%;
            animation: progressGlow 2s linear infinite;
            transition: width 0.5s ease;
        }

        @keyframes progressGlow {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }

        /* ===== GAMING BUTTONS ===== */
        .gaming-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 12px 24px;
            border: none;
            border-radius: 12px;
            font-family: 'Orbitron', sans-serif;
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            cursor: pointer;
            transition: all 0.3s;
            text-decoration: none;
            color: #fff;
            position: relative;
            overflow: hidden;
        }

        .gaming-btn::before {
            content: '';
            position: absolute;
            top: -2px;
            left: -2px;
            right: -2px;
            bottom: -2px;
            border-radius: 14px;
            background: linear-gradient(90deg, #ff00ff, #00ffff, #ff6600, #ff00ff);
            background-size: 300% 100%;
            animation: btnBorder 3s linear infinite;
            z-index: -1;
            opacity: 0;
            transition: opacity 0.3s;
        }

        .gaming-btn:hover::before {
            opacity: 1;
        }

        .gaming-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 0 40px rgba(255, 0, 255, 0.2);
        }

        @keyframes btnBorder {
            0% { background-position: 0% 50%; }
            100% { background-position: 300% 50%; }
        }

        .gaming-btn-telegram {
            background: linear-gradient(135deg, #0088cc, #0055aa);
        }

        .gaming-btn-donate {
            background: linear-gradient(135deg, #ff0088, #8800ff);
            animation: donateGlow 2s ease-in-out infinite alternate;
        }

        @keyframes donateGlow {
            0% { box-shadow: 0 0 20px rgba(255,0,136,0.1); }
            100% { box-shadow: 0 0 50px rgba(136,0,255,0.3); }
        }

        .gaming-btn-secondary {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
        }

        .gaming-btn-secondary:hover {
            background: rgba(255,255,255,0.1);
        }

        .gaming-btn-copy {
            background: linear-gradient(135deg, #6366f1, #4f46e5);
        }

        .gaming-btn-copy:hover {
            box-shadow: 0 0 30px rgba(99, 102, 241, 0.3);
        }

        /* ===== INPUT ===== */
        .gaming-input {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: 12px;
            padding: 12px 16px;
            color: #fff;
            font-family: 'Exo 2', monospace;
            font-size: 13px;
            outline: none;
            transition: all 0.3s;
            width: 100%;
        }

        .gaming-input:focus {
            border-color: #a78bfa;
            box-shadow: 0 0 30px rgba(167, 139, 250, 0.1);
        }

        .gaming-input::placeholder {
            color: rgba(255,255,255,0.2);
        }

        /* ===== LINKS GRID ===== */
        .gaming-link-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        @media (max-width: 768px) {
            .gaming-link-grid {
                grid-template-columns: 1fr;
            }
        }

        .gaming-link-item {
            background: rgba(255,255,255,0.02);
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: 12px;
            padding: 12px 16px;
            transition: all 0.3s;
        }

        .gaming-link-item:hover {
            border-color: rgba(167, 139, 250, 0.3);
        }

        /* ===== APP BUTTONS ===== */
        .gaming-app-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 10px;
        }

        @media (max-width: 768px) {
            .gaming-app-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        .gaming-app-btn {
            background: rgba(255,255,255,0.02);
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: 12px;
            padding: 12px;
            text-align: center;
            color: rgba(255,255,255,0.6);
            text-decoration: none;
            font-family: 'Orbitron', sans-serif;
            font-size: 10px;
            letter-spacing: 1px;
            transition: all 0.3s;
        }

        .gaming-app-btn:hover {
            border-color: rgba(167, 139, 250, 0.3);
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 0 30px rgba(167, 139, 250, 0.05);
        }

        /* ===== THEME TOGGLE ===== */
        .gaming-toggle {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: 10px;
            padding: 8px 16px;
            color: rgba(255,255,255,0.4);
            font-family: 'Orbitron', sans-serif;
            font-size: 10px;
            letter-spacing: 1px;
            cursor: pointer;
            transition: all 0.3s;
        }

        .gaming-toggle:hover {
            border-color: rgba(167, 139, 250, 0.3);
            color: #fff;
        }

        /* ===== QR MODAL ===== */
        .gaming-modal {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.85);
            backdrop-filter: blur(20px);
            z-index: 100;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 20px;
            opacity: 0;
            transition: opacity 0.3s;
        }

        .gaming-modal.active {
            display: flex;
            opacity: 1;
        }

        .gaming-modal-card {
            background: rgba(10,10,10,0.95);
            border: 2px solid transparent;
            border-radius: 24px;
            padding: 40px;
            max-width: 400px;
            width: 100%;
            animation: borderGlow 4s ease-in-out infinite alternate;
            text-align: center;
        }

        .gaming-modal-card img {
            border-radius: 16px;
            background: #fff;
            padding: 10px;
        }

        /* ===== TOAST ===== */
        .gaming-toast {
            position: fixed;
            top: 30px;
            left: 50%;
            transform: translateX(-50%) translateY(-20px);
            background: rgba(10,10,10,0.95);
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: 16px;
            padding: 12px 24px;
            font-family: 'Orbitron', sans-serif;
            font-size: 12px;
            color: #fff;
            z-index: 200;
            opacity: 0;
            transition: all 0.3s;
            pointer-events: none;
            box-shadow: 0 0 60px rgba(0,0,0,0.5);
        }

        .gaming-toast.active {
            opacity: 1;
            transform: translateX(-50%) translateY(0);
        }

        /* ===== SCROLLBAR ===== */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: rgba(255,255,255,0.02); }
        ::-webkit-scrollbar-thumb { background: linear-gradient(180deg, #ff00ff, #00ffff); border-radius: 10px; }
    </style>
</head>
<body>

    <!-- ===== BACKGROUND ===== -->
    <div class="gaming-bg"></div>

    <!-- ===== PARTICLES ===== -->
    <div class="particles" id="particles"></div>

    <!-- ===== TOAST ===== -->
    <div class="gaming-toast" id="toast">✅ Copied!</div>

    <!-- ===== MAIN CONTAINER ===== -->
    <div class="gaming-container">

        <!-- ===== TOP TOGGLES ===== -->
        <div style="display:flex; justify-content:flex-end; gap:12px; margin-bottom:20px;">
            <button class="gaming-toggle" onclick="toggleTheme()" id="themeToggle">
                <span id="themeIcon">🌙</span> <span id="themeLabel">DARK</span>
            </button>
            <button class="gaming-toggle" onclick="toggleLang()" id="langToggle">
                <span id="langIcon">🇺🇸</span> <span id="langLabel">EN</span>
            </button>
        </div>

        <!-- ===== MAIN CARD ===== -->
        <div class="gaming-card">

            <!-- ===== PROFILE ===== -->
            <div style="text-align:center; margin-bottom:30px;">
                <div class="gaming-avatar" id="avatar">👾</div>
                <h1 class="gaming-title" style="font-size:28px;">__USER_NAME__</h1>
                <p style="font-family:'Orbitron',monospace; font-size:11px; color:rgba(255,255,255,0.2); letter-spacing:2px; margin-top:4px;">__USER_ID__</p>
                <div style="margin-top:12px;">
                    <span class="gaming-badge active" id="statusBadge">🟢 ACTIVE</span>
                </div>
            </div>

            <!-- ===== STATS ROW ===== -->
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:30px;">
                <!-- Total -->
                <div style="background:rgba(255,255,255,0.02); border-radius:16px; padding:20px; border:1px solid rgba(255,255,255,0.03);">
                    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
                        <span class="gaming-label">📊 TOTAL</span>
                        <span style="font-family:'Orbitron',sans-serif; font-size:11px; color:rgba(255,255,255,0.2);">DATA</span>
                    </div>
                    <div style="display:flex; align-items:baseline; gap:6px;">
                        <span class="gaming-stat" id="totalGb">__TOTAL_GB__</span>
                        <span class="gaming-stat-small">/ __LIMIT_TOTAL_GB__ GB</span>
                    </div>
                    <div class="gaming-progress">
                        <div class="gaming-progress-fill" id="totalProgress" style="width:__TOTAL_PERCENT__%;"></div>
                    </div>
                    <div style="display:flex; justify-content:space-between; margin-top:4px;">
                        <span class="gaming-label" style="font-size:8px;">USAGE</span>
                        <span style="font-family:'Orbitron',sans-serif; font-size:10px; color:rgba(255,255,255,0.3);" id="totalPercentLabel">__TOTAL_PERCENT__%</span>
                    </div>
                </div>

                <!-- Daily -->
                <div style="background:rgba(255,255,255,0.02); border-radius:16px; padding:20px; border:1px solid rgba(255,255,255,0.03);">
                    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
                        <span class="gaming-label">⏱ DAILY</span>
                        <span style="font-family:'Orbitron',sans-serif; font-size:11px; color:rgba(255,255,255,0.2);">LIMIT</span>
                    </div>
                    <div style="display:flex; align-items:baseline; gap:6px;">
                        <span class="gaming-stat" id="dailyGb">__DAILY_GB__</span>
                        <span class="gaming-stat-small">/ __LIMIT_DAILY_GB__ GB</span>
                    </div>
                    <div class="gaming-progress">
                        <div class="gaming-progress-fill" id="dailyProgress" style="width:__DAILY_PERCENT__%;"></div>
                    </div>
                    <div style="display:flex; justify-content:space-between; margin-top:4px;">
                        <span class="gaming-label" style="font-size:8px;">USAGE</span>
                        <span style="font-family:'Orbitron',sans-serif; font-size:10px; color:rgba(255,255,255,0.3);" id="dailyPercentLabel">__DAILY_PERCENT__%</span>
                    </div>
                </div>
            </div>

            <!-- ===== INFO ROW ===== -->
            <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:15px; margin-bottom:30px;">
                <div style="text-align:center; background:rgba(255,255,255,0.02); border-radius:12px; padding:12px; border:1px solid rgba(255,255,255,0.03);">
                    <span class="gaming-label">📅 EXPIRY</span>
                    <p style="font-family:'Orbitron',sans-serif; font-size:13px; font-weight:600; margin-top:4px;" id="expiryDate">__EXPIRY_DATE__</p>
                </div>
                <div style="text-align:center; background:rgba(255,255,255,0.02); border-radius:12px; padding:12px; border:1px solid rgba(255,255,255,0.03);">
                    <span class="gaming-label">🌐 IP</span>
                    <p style="font-family:'Orbitron',sans-serif; font-size:13px; font-weight:600; margin-top:4px;" id="clientIp">Detecting...</p>
                </div>
                <div style="text-align:center; background:rgba(255,255,255,0.02); border-radius:12px; padding:12px; border:1px solid rgba(255,255,255,0.03);">
                    <span class="gaming-label">📡 STATUS</span>
                    <p style="font-family:'Orbitron',sans-serif; font-size:13px; font-weight:600; margin-top:4px; color:#00ff64;" id="statusText">ONLINE</p>
                </div>
            </div>

            <!-- ===== SUBSCRIPTION LINK ===== -->
            <div style="background:rgba(255,255,255,0.02); border-radius:16px; padding:20px; border:1px solid rgba(255,255,255,0.03); margin-bottom:25px;">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
                    <span class="gaming-label">🔗 UNIVERSAL LINK</span>
                    <span style="font-family:'Orbitron',sans-serif; font-size:9px; color:rgba(255,255,255,0.2); letter-spacing:2px;">AUTO-DETECT</span>
                </div>
                <div style="display:flex; gap:10px; flex-wrap:wrap;">
                    <input type="text" id="linkNormal" value="__SYNC_NORMAL__" readonly class="gaming-input" style="flex:1; min-width:200px;">
                    <button onclick="copyLink('linkNormal')" class="gaming-btn gaming-btn-copy" style="padding:12px 20px;">📋 COPY</button>
                    <button onclick="showQR('__SYNC_NORMAL__')" class="gaming-btn gaming-btn-secondary" style="padding:12px 16px;">📱 QR</button>
                </div>
            </div>

            <!-- ===== FORMAT LINKS ===== -->
            <div style="margin-bottom:25px;">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
                    <span class="gaming-label">🎯 FORMATS</span>
                    <span style="font-family:'Orbitron',sans-serif; font-size:9px; color:rgba(255,255,255,0.2); letter-spacing:2px;">SPECIFIC</span>
                </div>
                <div class="gaming-link-grid">
                    <div class="gaming-link-item">
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
                            <span style="font-family:'Orbitron',sans-serif; font-size:9px; color:rgba(255,255,255,0.3);">RAW</span>
                            <button onclick="copyLink('linkRaw')" class="gaming-btn gaming-btn-copy" style="padding:4px 12px; font-size:9px;">COPY</button>
                        </div>
                        <input type="text" id="linkRaw" value="__SYNC_RAW__" readonly class="gaming-input" style="font-size:11px; padding:8px 12px;">
                    </div>
