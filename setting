<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>پنل مدیریت Xray</title>
    <link href="https://fonts.googleapis.com/css2?family=Vazirmatn:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* =============================================
                   RESET & VARIABLES (مشابه Marzban)
                ============================================= */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg-primary: #0f0f1a;
            --bg-secondary: #1a1a2e;
            --bg-card: rgba(255, 255, 255, 0.03);
            --bg-hover: rgba(255, 255, 255, 0.05);
            --border-color: rgba(255, 255, 255, 0.06);
            --text-primary: #ffffff;
            --text-secondary: rgba(255, 255, 255, 0.6);
            --text-muted: rgba(255, 255, 255, 0.3);
            --accent-purple: #818cf8;
            --accent-blue: #4f46e5;
            --accent-green: #34d399;
            --accent-amber: #fbbf24;
            --accent-pink: #f472b6;
            --accent-red: #f87171;
            --shadow-card: 0 8px 32px rgba(0, 0, 0, 0.4);
            --radius: 12px;
            --transition: all 0.3s ease;
        }

        body {
            font-family: 'Vazirmatn', sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            min-height: 100vh;
            display: flex;
            direction: rtl;
        }

        /* =============================================
                   SIDEBAR (مشابه Marzban)
                ============================================= */
        .sidebar {
            width: 280px;
            background: var(--bg-secondary);
            border-left: 1px solid var(--border-color);
            height: 100vh;
            position: sticky;
            top: 0;
            padding: 24px 16px;
            display: flex;
            flex-direction: column;
            gap: 4px;
            overflow-y: auto;
            transition: var(--transition);
            z-index: 100;
        }

        .sidebar-logo {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 0 8px 24px;
            border-bottom: 1px solid var(--border-color);
            margin-bottom: 20px;
        }

        .sidebar-logo .icon {
            width: 42px;
            height: 42px;
            background: linear-gradient(135deg, var(--accent-purple), var(--accent-blue));
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            color: #fff;
        }

        .sidebar-logo .text {
            font-size: 20px;
            font-weight: 800;
            letter-spacing: -0.5px;
        }

        .sidebar-logo .text span {
            color: var(--accent-purple);
        }

        .sidebar-logo .version {
            font-size: 10px;
            color: var(--text-muted);
            background: rgba(255, 255, 255, 0.05);
            padding: 2px 8px;
            border-radius: 10px;
            margin-right: auto;
        }

        .sidebar-item {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 12px 16px;
            border-radius: var(--radius);
            color: var(--text-secondary);
            text-decoration: none;
            transition: var(--transition);
            cursor: pointer;
            font-weight: 500;
            font-size: 14px;
            position: relative;
        }

        .sidebar-item:hover {
            background: var(--bg-hover);
            color: var(--text-primary);
        }

        .sidebar-item.active {
            background: rgba(129, 140, 248, 0.12);
            color: var(--accent-purple);
        }

        .sidebar-item.active::before {
            content: '';
            position: absolute;
            right: 0;
            top: 50%;
            transform: translateY(-50%);
            width: 3px;
            height: 24px;
            background: var(--accent-purple);
            border-radius: 0 4px 4px 0;
        }

        .sidebar-item i {
            width: 20px;
            text-align: center;
            font-size: 16px;
        }

        .sidebar-item .badge {
            margin-right: auto;
            background: rgba(129, 140, 248, 0.15);
            color: var(--accent-purple);
            font-size: 10px;
            padding: 2px 10px;
            border-radius: 20px;
            font-weight: 600;
        }

        .sidebar-divider {
            height: 1px;
            background: var(--border-color);
            margin: 8px 12px;
        }

        .sidebar-footer {
            margin-top: auto;
            padding-top: 16px;
            border-top: 1px solid var(--border-color);
        }

        /* =============================================
                   MAIN CONTENT
                ============================================= */
        .main {
            flex: 1;
            padding: 24px 32px;
            overflow-y: auto;
            max-height: 100vh;
        }

        /* =============================================
                   TOP BAR (مشابه Marzban)
                ============================================= */
        .topbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 28px;
            flex-wrap: wrap;
            gap: 16px;
        }

        .topbar-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .topbar-left h1 {
            font-size: 22px;
            font-weight: 800;
        }

        .topbar-left .subtitle {
            font-size: 13px;
            color: var(--text-muted);
            font-weight: 400;
        }

        .topbar-actions {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        /* =============================================
                   BUTTONS
                ============================================= */
        .btn {
            padding: 8px 18px;
            border-radius: 10px;
            border: none;
            font-family: inherit;
            font-weight: 600;
            font-size: 13px;
            cursor: pointer;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--accent-purple), var(--accent-blue));
            color: #fff;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(129, 140, 248, 0.3);
        }

        .btn-outline {
            background: transparent;
            border: 1px solid var(--border-color);
            color: var(--text-secondary);
        }

        .btn-outline:hover {
            background: var(--bg-hover);
            color: var(--text-primary);
        }

        .btn-danger {
            background: rgba(248, 113, 113, 0.12);
            color: var(--accent-red);
        }

        .btn-danger:hover {
            background: rgba(248, 113, 113, 0.25);
        }

        .btn-success {
            background: rgba(52, 211, 153, 0.12);
            color: var(--accent-green);
        }

        .btn-success:hover {
            background: rgba(52, 211, 153, 0.25);
        }

        .btn-sm {
            padding: 4px 12px;
            font-size: 11px;
            border-radius: 8px;
        }

        /* =============================================
                   SEARCH
                ============================================= */
        .search-box {
            display: flex;
            align-items: center;
            background: var(--bg-secondary);
            border: 1px solid var(--border-color);
            border-radius: 10px;
            padding: 0 14px;
            transition: var(--transition);
        }

        .search-box:focus-within {
            border-color: var(--accent-purple);
        }

        .search-box input {
            background: transparent;
            border: none;
            padding: 9px 10px;
            color: var(--text-primary);
            font-family: inherit;
            font-size: 13px;
            width: 200px;
            outline: none;
        }

        .search-box input::placeholder {
            color: var(--text-muted);
        }

        .search-box i {
            color: var(--text-muted);
            font-size: 14px;
        }

        /* =============================================
                   STATS GRID (مشابه Marzban Dashboard)
                ============================================= */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 16px;
            margin-bottom: 28px;
        }

        .stat-card {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: var(--radius);
            padding: 18px 22px;
            transition: var(--transition);
        }

        .stat-card:hover {
            background: var(--bg-hover);
            transform: translateY(-2px);
        }

        .stat-card .label {
            font-size: 12px;
            color: var(--text-muted);
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .stat-card .value {
            font-size: 28px;
            font-weight: 800;
            margin: 4px 0 2px;
        }

        .stat-card .change {
            font-size: 12px;
            font-weight: 600;
        }

        .stat-card .change.up {
            color: var(--accent-green);
        }
        .stat-card .change.down {
            color: var(--accent-red);
        }

        .stat-card.purple .value {
            color: var(--accent-purple);
        }
        .stat-card.green .value {
            color: var(--accent-green);
        }
        .stat-card.amber .value {
            color: var(--accent-amber);
        }
        .stat-card.pink .value {
            color: var(--accent-pink);
        }

        /* =============================================
                   PANEL CARDS
                ============================================= */
        .panel-card {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: var(--radius);
            padding: 24px;
            margin-bottom: 24px;
        }

        .panel-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            flex-wrap: wrap;
            gap: 12px;
        }

        .panel-header h3 {
            font-size: 16px;
            font-weight: 700;
        }

        .panel-header .subtitle {
            font-size: 13px;
            color: var(--text-muted);
            font-weight: 400;
        }

        .panel-header .actions {
            display: flex;
            gap: 8px;
        }

        /* =============================================
                   TABLES (مشابه Marzban User List)
                ============================================= */
        .table-wrapper {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead th {
            text-align: right;
            padding: 12px 16px;
            font-size: 11px;
            font-weight: 600;
            color: var(--text-muted);
            border-bottom: 1px solid var(--border-color);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        tbody td {
            padding: 14px 16px;
            font-size: 13px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.03);
        }

        tbody tr:hover {
            background: var(--bg-hover);
        }

        .status-badge {
            padding: 4px 14px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .status-badge.active {
            background: rgba(52, 211, 153, 0.12);
            color: var(--accent-green);
        }

        .status-badge.expired {
            background: rgba(248, 113, 113, 0.12);
            color: var(--accent-red);
        }

        .status-badge.limited {
            background: rgba(251, 191, 36, 0.12);
            color: var(--accent-amber);
        }

        .status-badge.paused {
            background: rgba(129, 140, 248, 0.12);
            color: var(--accent-purple);
        }

        .status-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            display: inline-block;
        }

        .status-dot.on {
            background: var(--accent-green);
        }
        .status-dot.off {
            background: var(--accent-red);
        }
        .status-dot.warn {
            background: var(--accent-amber);
        }
        .status-dot.pause {
            background: var(--accent-purple);
        }

        .usage-bar {
            width: 100px;
            height: 4px;
            background: rgba(255, 255, 255, 0.06);
            border-radius: 4px;
            overflow: hidden;
            display: inline-block;
            vertical-align: middle;
            margin-right: 8px;
        }

        .usage-bar .fill {
            height: 100%;
            border-radius: 4px;
            transition: width 0.6s ease;
        }

        .usage-bar .fill.purple {
            background: var(--accent-purple);
        }
        .usage-bar .fill.green {
            background: var(--accent-green);
        }
        .usage-bar .fill.amber {
            background: var(--accent-amber);
        }
        .usage-bar .fill.red {
            background: var(--accent-red);
        }

        .user-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 14px;
            background: rgba(129, 140, 248, 0.15);
            color: var(--accent-purple);
        }

        /* =============================================
                   SYSTEM STATUS BAR (مشابه Marzban)
                ============================================= */
        .system-status {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 12px;
            margin-top: 16px;
        }

        .status-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            background: var(--bg-secondary);
            border-radius: var(--radius);
            border: 1px solid var(--border-color);
        }

        .status-item .label {
            font-size: 12px;
            color: var(--text-muted);
        }

        .status-item .value {
            font-size: 14px;
            font-weight: 600;
        }

        .status-item .indicator {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            margin-right: auto;
        }

        .status-item .indicator.online {
            background: var(--accent-green);
        }
        .status-item .indicator.warning {
            background: var(--accent-amber);
        }
        .status-item .indicator.offline {
            background: var(--accent-red);
        }

        /* =============================================
                   RESPONSIVE (مشابه Marzban)
                ============================================= */
        @media (max-width: 1024px) {
            .sidebar {
                width: 72px;
                padding: 16px 8px;
            }
            .sidebar .text,
            .sidebar .badge,
            .sidebar .version,
            .sidebar .label-text {
                display: none;
            }
            .sidebar-item {
                justify-content: center;
                padding: 12px;
                border-radius: 10px;
            }
            .sidebar-item.active::before {
                display: none;
            }
            .sidebar-item.active {
                background: rgba(129, 140, 248, 0.15);
            }
            .sidebar-logo {
                justify-content: center;
                padding-bottom: 16px;
            }
            .sidebar-logo .text {
                display: none;
            }
            .sidebar-footer .sidebar-item .label-text {
                display: none;
            }
            .main {
                padding: 16px 20px;
            }
        }

        @media (max-width: 640px) {
            .sidebar {
                display: none;
            }
            .main {
                padding: 12px;
            }
            .stats-grid {
                grid-template-columns: 1fr 1fr;
            }
            .topbar {
                flex-direction: column;
                align-items: stretch;
            }
            .topbar-actions {
                flex-wrap: wrap;
            }
            .search-box input {
                width: 100%;
            }
            .panel-header {
                flex-direction: column;
                align-items: stretch;
            }
            .system-status {
                grid-template-columns: 1fr 1fr;
            }
            table {
                font-size: 12px;
            }
            thead th,
            tbody td {
                padding: 8px 10px;
            }
            .usage-bar {
                width: 60px;
            }
        }

        /* =============================================
                   SCROLLBAR
                ============================================= */
        ::-webkit-scrollbar {
            width: 4px;
            height: 4px;
        }
        ::-webkit-scrollbar-track {
            background: transparent;
        }
        ::-webkit-scrollbar-thumb {
            background: var(--accent-purple);
            border-radius: 4px;
        }

        /* =============================================
                   ANIMATIONS
                ============================================= */
        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(8px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        .fade-in {
            animation: fadeIn 0.4s ease-out;
        }

        @keyframes pulse {
            0%,
            100% {
                opacity: 1;
            }
            50% {
                opacity: 0.3;
            }
        }
        .pulse {
            animation: pulse 2s infinite;
        }

        /* =============================================
                   TOOLTIP
                ============================================= */
        .tooltip {
            position: relative;
        }
        .tooltip:hover::after {
            content: attr(data-tip);
            position: absolute;
            bottom: 100%;
            left: 50%;
            transform: translateX(-50%);
            background: var(--bg-secondary);
            color: var(--text-primary);
            padding: 4px 12px;
            border-radius: 6px;
            font-size: 11px;
            white-space: nowrap;
            border: 1px solid var(--border-color);
        }
    </style>
</head>
<body>

    <!-- =============================================
    SIDEBAR
    ============================================= -->
    <aside class="sidebar">
        <div class="sidebar-logo">
            <div class="icon">🚀</div>
            <div class="text">Xray<span>Panel</span></div>
            <span class="version">v2.0</span>
        </div>

        <a class="sidebar-item active">
            <i class="fas fa-chart-pie"></i>
            <span class="label-text">داشبورد</span>
        </a>
        <a class="sidebar-item">
            <i class="fas fa-users"></i>
            <span class="label-text">کاربران</span>
            <span class="badge">۱۲</span>
        </a>
        <a class="sidebar-item">
            <i class="fas fa-server"></i>
            <span class="label-text">سرورها</span>
            <span class="badge">۳</span>
        </a>
        <a class="sidebar-item">
            <i class="fas fa-plug"></i>
            <span class="label-text">Inbound</span>
        </a>
        <a class="sidebar-item">
            <i class="fas fa-chart-line"></i>
            <span class="label-text">آمار</span>
        </a>

        <div class="sidebar-divider"></div>

        <a class="sidebar-item">
            <i class="fas fa-cog"></i>
            <span class="label-text">تنظیمات</span>
        </a>
        <a class="sidebar-item">
            <i class="fas fa-shield-alt"></i>
            <span class="label-text">امنیت</span>
        </a>

        <div class="sidebar-footer">
            <a class="sidebar-item">
                <i class="fas fa-user-circle"></i>
                <span class="label-text">پروفایل</span>
            </a>
            <a class="sidebar-item" style="color: var(--accent-red);">
                <i class="fas fa-sign-out-alt"></i>
                <span class="label-text">خروج</span>
            </a>
        </div>
    </aside>

    <!-- =============================================
    MAIN CONTENT
    ============================================= -->
    <main class="main fade-in">

        <!-- ===== TOPBAR ===== -->
        <div class="topbar">
            <div class="topbar-left">
                <h1>📊 داشبورد</h1>
                <span class="subtitle">خلاصه وضعیت سیستم</span>
            </div>
            <div class="topbar-actions">
                <div class="search-box">
                    <i class="fas fa-search"></i>
                    <input type="text" placeholder="جستجو..." />
                </div>
                <button class="btn btn-primary">
                    <i class="fas fa-plus"></i> کاربر جدید
                </button>
                <button class="btn btn-outline">
                    <i class="fas fa-sync-alt"></i>
                </button>
            </div>
        </div>

        <!-- ===== STATS ===== -->
        <div class="stats-grid">
            <div class="stat-card purple">
                <div class="label">کل کاربران</div>
                <div class="value">۱۲</div>
                <div class="change up">↑ ۲ جدید</div>
            </div>
            <div class="stat-card green">
                <div class="label">فعال</div>
                <div class="value">۸</div>
                <div class="change up">↑ ۶۷٪</div>
            </div>
            <div class="stat-card amber">
                <div class="label">مصرف امروز</div>
                <div class="value">۲.۴GB</div>
                <div class="change up">↑ ۱۲٪</div>
            </div>
            <div class="stat-card pink">
                <div class="label">کل مصرف</div>
                <div class="value">۴۷.۸GB</div>
                <div class="change down">↓ ۳٪</div>
            </div>
        </div>

        <!-- ===== SYSTEM STATUS ===== -->
        <div class="panel-card">
            <div class="panel-header">
                <h3>🖥️ وضعیت سیستم</h3>
                <span class="subtitle">آخرین بروزرسانی: لحظه‌ای</span>
            </div>
            <div class="system-status">
                <div class="status-item">
                    <span class="indicator online"></span>
                    <div>
                        <div class="label">سرور اصلی</div>
                        <div class="value">آنلاین</div>
                    </div>
                </div>
                <div class="status-item">
                    <span class="indicator online"></span>
                    <div>
                        <div class="label">CPU</div>
                        <div class="value">۱۲٪</div>
                    </div>
                </div>
                <div class="status-item">
                    <span class="indicator warning"></span>
                    <div>
                        <div class="label">RAM</div>
                        <div class="value">۴۳٪</div>
                    </div>
                </div>
                <div class="status-item">
                    <span class="indicator online"></span>
                    <div>
                        <div class="label">Uptime</div>
                        <div class="value">۱۴ روز</div>
                    </div>
                </div>
                <div class="status-item">
                    <span class="indicator online"></span>
                    <div>
                        <div class="label">Xray Core</div>
                        <div class="value">v1.8.4</div>
                    </div>
                </div>
                <div class="status-item">
                    <span class="indicator online"></span>
                    <div>
                        <div class="label">اتصال اینترنت</div>
                        <div class="value">پایدار</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== USERS TABLE ===== -->
        <div class="panel-card">
            <div class="panel-header">
                <div>
                    <h3>👤 لیست کاربران</h3>
                    <span class="subtitle">۱۲ کاربر فعال • ۴ کاربر غیرفعال</span>
                </div>
                <div class="actions">
                    <button class="btn btn-outline btn-sm">
                        <i class="fas fa-download"></i> خروجی
                    </button>
                    <button class="btn btn-primary btn-sm">
                        <i class="fas fa-plus"></i> افزودن
                    </button>
                </div>
            </div>

            <div class="table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th>کاربر</th>
                            <th>شناسه</th>
                            <th>مصرف</th>
                            <th>سهمیه</th>
                            <th>وضعیت</th>
                            <th>انقضا</th>
                            <th>عملیات</th>
