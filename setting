    <!-- ===== QR MODAL ===== -->
    <div class="modal-overlay" id="qrModal">
        <div class="modal-content">
            <h3><i class="fas fa-qrcode" style="color:var(--accent-purple);"></i> اسکن کنید</h3>
            <div class="qr-wrapper">
                <img id="qrImage" src="" alt="QR Code">
            </div>
            <div class="link-text" id="qrLinkText">لینک</div>
            <button class="btn-close" onclick="closeQR()">بستن</button>
        </div>
    </div>

    <script>
        // =============================================
        // DATA (مشابه Marzban API Response)
        // =============================================
        const userData = {
            name: 'Sanaei',
            id: '152y5rt1mjwh94ny',
            status: 'active', // active | expired | limited
            upload: '43.35MB',
            download: '481.31MB',
            usage: '524.66MB',
            quota: '1.00GB',
            remaining: '499.34MB',
            percent: 52,
            expiry: '۱۴۰۴/۰۴/۲۵',
            lastOnline: '۶/۶/۲۰۲۴، ۱۰:۱۴:۱۸ ب.ظ',
            server: 'iran2.imsurn.ir',
            universalLink: 'vless://50a592ee-404d-424b-b758-4e98389c4090@iran2.imsurn.ir:25539?encryption=none&headerType=http&host=nobi...',
            rawLink: 'vless://50a592ee-404d-424b-b758-4e98389c4090@iran2.imsurn.ir:25539?encryption=none',
            base64Link: 'dmxlc3M6Ly81MGE1OTJlZS00MDRkLTQyNGItYjc1OC00ZTk4Mzg5YzQwOTBAaXJhbjIuaW1zdXJuLmlyOjI1NTM5P2VuY3J5cHRpb249bm9uZQ==',
            singboxLink: 'https://example.com/sub/singbox/152y5rt1mjwh94ny',
            clashLink: 'https://example.com/sub/clash/152y5rt1mjwh94ny',
            timeRemaining: '29 روز'
        };

        // =============================================
        // I18N
        // =============================================
        const i18n = {
            fa: {
                copy: 'کپی',
                copied: 'کپی شد!',
                qr: 'QR',
                close: 'بستن',
                qrTitle: 'اسکن کد QR',
                active: 'فعال',
                expired: 'منقضی',
                limited: 'محدود',
                dark: 'تاریک',
                light: 'روشن',
                lang: 'FA'
            },
            en: {
                copy: 'Copy',
                copied: 'Copied!',
                qr: 'QR',
                close: 'Close',
                qrTitle: 'Scan QR Code',
                active: 'Active',
                expired: 'Expired',
                limited: 'Limited',
                dark: 'Dark',
                light: 'Light',
                lang: 'EN'
            }
        };

        let currentLang = 'fa';
        let isDark = true;

        // =============================================
        // RENDER FUNCTIONS
        // =============================================
        function renderProfile() {
            document.getElementById('userName').textContent = userData.name;
            document.getElementById('userId').textContent = 'شناسه: ' + userData.id;

            const badge = document.getElementById('statusBadge');
            const statusText = document.getElementById('statusText');
            const dot = badge.querySelector('.status-dot');

            const statusMap = {
                active: { class: 'active', dotClass: 'on', text: currentLang === 'fa' ? 'فعال' : 'Active' },
                expired: { class: 'expired', dotClass: 'off', text: currentLang === 'fa' ? 'منقضی' : 'Expired' },
                limited: { class: 'limited', dotClass: 'warn', text: currentLang === 'fa' ? 'محدود' : 'Limited' }
            };

            const s = statusMap[userData.status] || statusMap.active;
            badge.className = 'status-badge ' + s.class;
            dot.className = 'status-dot ' + s.dotClass;
            statusText.textContent = s.text;
        }

        function renderStats() {
            document.getElementById('uploadValue').textContent = userData.upload;
            document.getElementById('downloadValue').textContent = userData.download;
            document.getElementById('usageValue').textContent = userData.usage;
            document.getElementById('quotaTotal').textContent = userData.quota;
            document.getElementById('usageProgress').style.width = userData.percent + '%';
            document.getElementById('timeRemaining').textContent = userData.timeRemaining;
        }

        function renderLinks() {
            document.getElementById('universalLink').value = userData.universalLink;
            document.getElementById('rawLink').value = userData.rawLink;
            document.getElementById('base64Link').value = userData.base64Link;
            document.getElementById('singboxLink').value = userData.singboxLink;
            document.getElementById('clashLink').value = userData.clashLink;
        }

        function renderDetails() {
            document.getElementById('expiryDate').textContent = userData.expiry;
            document.getElementById('lastOnline').textContent = userData.lastOnline;
            document.getElementById('remainingQuota').textContent = userData.remaining;
            document.getElementById('serverName').textContent = userData.server;
        }

        // =============================================
        // UTILITY FUNCTIONS
        // =============================================
        function copyLink(id) {
            const el = document.getElementById(id);
            el.select();
            navigator.clipboard.writeText(el.value).then(() => {
                showToast(i18n[currentLang].copied);
            });
        }

        function showToast(message) {
            const toast = document.getElementById('toast');
            document.getElementById('toastMessage').textContent = message;
            toast.classList.add('show');
            clearTimeout(toast._timeout);
            toast._timeout = setTimeout(() => {
                toast.classList.remove('show');
            }, 2500);
        }

        function showQR(linkId) {
            const el = document.getElementById(linkId);
            const url = el.value;
            const modal = document.getElementById('qrModal');
            document.getElementById('qrLinkText').textContent = url;
            document.getElementById('qrImage').src = 'https://api.qrserver.com/v1/create-qr-code/?size=250x250&data=' +
                encodeURIComponent(url);
            modal.classList.add('show');
        }

        function closeQR() {
            document.getElementById('qrModal').classList.remove('show');
        }

        // Close QR with Escape key
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeQR();
        });

        // Click outside to close
        document.getElementById('qrModal').addEventListener('click', (e) => {
            if (e.target === e.currentTarget) closeQR();
        });

        function importToApp(app) {
            const link = userData.universalLink;
            const name = userData.name;

            const appLinks = {
                v2rayng: 'v2rayng://install-sub?url=' + encodeURIComponent(link) + '&name=' + encodeURIComponent(name),
                v2rayn: 'v2rayn://install-sub?url=' + encodeURIComponent(link) + '&name=' + encodeURIComponent(name),
                shadowrocket: 'shadowrocket://add/sub://' + btoa(link) + '?title=' + encodeURIComponent(name),
                streisand: 'streisand://import/' + encodeURIComponent(link),
                clashmeta: 'clashmeta://install-config?url=' + encodeURIComponent(link),
                singbox: 'singbox://install-sub?url=' + encodeURIComponent(link)
            };

            const url = appLinks[app];
            if (url) {
                window.location.href = url;
                showToast('در حال باز کردن ' + app + '...');
            }
        }

        function toggleTheme() {
            isDark = !isDark;
            const root = document.documentElement;
            if (isDark) {
                root.style.setProperty('--bg-primary', '#0b0f19');
                root.style.setProperty('--bg-card', 'rgba(17, 24, 39, 0.8)');
                root.style.setProperty('--text-primary', '#f9fafb');
                document.getElementById('theme-label').textContent = currentLang === 'fa' ? 'تاریک' : 'Dark';
            } else {
                root.style.setProperty('--bg-primary', '#f3f4f6');
                root.style.setProperty('--bg-card', 'rgba(255, 255, 255, 0.9)');
                root.style.setProperty('--text-primary', '#111827');
                document.getElementById('theme-label').textContent = currentLang === 'fa' ? 'روشن' : 'Light';
            }
            try { localStorage.setItem('sub-theme', isDark ? 'dark' : 'light'); } catch (e) {}
        }

        function toggleLang() {
            currentLang = currentLang === 'fa' ? 'en' : 'fa';
            const t = i18n[currentLang];
            document.getElementById('lang-label').textContent = t.lang;
            document.getElementById('theme-label').textContent = isDark ? t.dark : t.light;
            renderProfile();
            try { localStorage.setItem('sub-lang', currentLang); } catch (e) {}
        }

        // =============================================
        // FETCH CLIENT IP
        // =============================================
        fetch('https://api.ipify.org?format=json')
            .then(r => r.json())
            .then(data => {
                document.getElementById('clientIp').textContent = data.ip;
            })
            .catch(() => {
                document.getElementById('clientIp').textContent = 'نامشخص';
            });

        // =============================================
        // INIT
        // =============================================
        (function init() {
            // Load saved settings
            try {
                const savedTheme = localStorage.getItem('sub-theme');
                if (savedTheme === 'light') {
                    isDark = false;
                    document.documentElement.style.setProperty('--bg-primary', '#f3f4f6');
                    document.documentElement.style.setProperty('--bg-card', 'rgba(255, 255, 255, 0.9)');
                    document.documentElement.style.setProperty('--text-primary', '#111827');
                    document.getElementById('theme-label').textContent = 'روشن';
                }
                const savedLang = localStorage.getItem('sub-lang');
                if (savedLang === 'en') {
                    currentLang = 'en';
                    document.getElementById('lang-label').textContent = 'EN';
                    document.getElementById('theme-label').textContent = isDark ? 'Dark' : 'Light';
                }
            } catch (e) {}

            renderProfile();
            renderStats();
            renderLinks();
            renderDetails();

            // Set initial theme label
            document.getElementById('theme-label').textContent = isDark ?
                (currentLang === 'fa' ? 'تاریک' : 'Dark') :
                (currentLang === 'fa' ? 'روشن' : 'Light');

            console.log('✅ Xray Subscriber Panel loaded');
            console.log('👤 User:', userData.name);
        })();
    </script>

