    <!-- ===== QR MODAL ===== -->
    <div class="gaming-modal" id="qrModal">
        <div class="gaming-modal-card">
            <h3 style="font-family:'Orbitron',sans-serif; font-size:16px; margin-bottom:15px; color:#fff;">📱 SCAN QR</h3>
            <img id="qrImage" src="" alt="QR Code" style="width:200px; height:200px; margin:0 auto 15px; display:block;">
            <p id="qrText" style="font-family:'Exo 2',monospace; font-size:11px; color:rgba(255,255,255,0.4); word-break:break-all; margin-bottom:15px; background:rgba(255,255,255,0.02); padding:10px; border-radius:8px;"></p>
            <button onclick="closeQR()" class="gaming-btn gaming-btn-secondary" style="width:100%; justify-content:center;">CLOSE</button>
        </div>
    </div>

    <script>
        // =============================================
        // CONFIG
        // =============================================
        const STATUS_CODE = '__STATUS_CODE__';
        const USER_NAME = '__USER_NAME__';
        const SYNC_NORMAL = '__SYNC_NORMAL__';
        const SYNC_RAW = '__SYNC_RAW__';

        let currentLang = 'en';
        let isDark = true;

        // =============================================
        // I18N
        // =============================================
        const I18N = {
            en: {
                active: 'ACTIVE',
                paused: 'PAUSED',
                expired: 'EXPIRED',
                limit: 'LIMIT EXCEEDED',
                dailyLimit: 'DAILY LIMIT',
                online: 'ONLINE',
                offline: 'OFFLINE'
            },
            fa: {
                active: 'فعال',
                paused: 'متوقف',
                expired: 'منقضی',
                limit: 'رد شده',
                dailyLimit: 'رد روزانه',
                online: 'آنلاین',
                offline: 'آفلاین'
            }
        };

        // =============================================
        // DOM REFS
        // =============================================
        const statusBadge = document.getElementById('statusBadge');
        const statusText = document.getElementById('statusText');
        const totalProgress = document.getElementById('totalProgress');
        const dailyProgress = document.getElementById('dailyProgress');
        const totalPercentLabel = document.getElementById('totalPercentLabel');
        const dailyPercentLabel = document.getElementById('dailyPercentLabel');
        const expiryDate = document.getElementById('expiryDate');
        const clientIp = document.getElementById('clientIp');

        // =============================================
        // INIT
        // =============================================
        function init() {
            // Status
            const statusMap = {
                'active': { class: 'active', label: 'ACTIVE' },
                'paused': { class: 'paused', label: 'PAUSED' },
                'expired': { class: 'expired', label: 'EXPIRED' },
                'limit': { class: 'limit', label: 'LIMIT EXCEEDED' },
                'dailyLimit': { class: 'dailyLimit', label: 'DAILY LIMIT' }
            };
            const s = statusMap[STATUS_CODE] || statusMap['active'];
            statusBadge.textContent = `🟢 ${s.label}`;
            statusBadge.className = `gaming-badge ${s.class}`;
            statusText.textContent = s.label;
            statusText.style.color = s.class === 'active' ? '#00ff64' : '#ff4444';

            // Expiry
            const expiry = '__EXPIRY_DATE__';
            expiryDate.textContent = expiry;

            // Progress
            const totalP = parseFloat('__TOTAL_PERCENT__') || 0;
            const dailyP = parseFloat('__DAILY_PERCENT__') || 0;
            totalProgress.style.width = Math.min(100, totalP) + '%';
            dailyProgress.style.width = Math.min(100, dailyP) + '%';
            totalPercentLabel.textContent = Math.min(100, totalP) + '%';
            dailyPercentLabel.textContent = Math.min(100, dailyP) + '%';

            // Setup app links
            setupAppLinks();

            // Fetch IP
            fetch('https://api.ipify.org?format=json')
                .then(r => r.json())
                .then(data => { clientIp.textContent = data.ip; })
                .catch(() => { clientIp.textContent = 'Unknown'; });
        }

        // =============================================
        // APP LINKS
        // =============================================
        function setupAppLinks() {
            const base64 = btoa(SYNC_NORMAL);
            const normalEnc = encodeURIComponent(SYNC_NORMAL);
            const nameEnc = encodeURIComponent(USER_NAME);

            document.getElementById('appV2rayNG').href = `v2rayng://install-sub?url=${encodeURIComponent(SYNC_NORMAL + '?flag=base64')}&name=${nameEnc}`;
            document.getElementById('appV2rayN').href = `v2rayn://install-sub?url=${encodeURIComponent(SYNC_NORMAL)}&name=${nameEnc}`;
            document.getElementById('appShadowrocket').href = `shadowrocket://add/sub://${base64}?title=${nameEnc}`;
            document.getElementById('appStreisand').href = `streisand://import/${encodeURIComponent(SYNC_NORMAL)}`;
        }

        // =============================================
        // COPY
        // =============================================
        function copyLink(id) {
            const el = document.getElementById(id);
            if (!el) return;
            el.select();
            navigator.clipboard.writeText(el.value).then(() => {
                showToast('✅ Copied!');
            }).catch(() => {
                showToast('❌ Failed to copy');
            });
        }

        // =============================================
        // QR
        // =============================================
        function showQR(url) {
            const modal = document.getElementById('qrModal');
            document.getElementById('qrImage').src = `https://api.qrserver.com/v1/create-qr-code/?size=300x300&data=${encodeURIComponent(url)}`;
            document.getElementById('qrText').textContent = url;
            modal.classList.add('active');
        }

        function closeQR() {
            document.getElementById('qrModal').classList.remove('active');
        }

        // =============================================
        // TOAST
        // =============================================
        function showToast(msg) {
            const t = document.getElementById('toast');
            t.textContent = msg;
            t.classList.add('active');
            setTimeout(() => { t.classList.remove('active'); }, 2500);
        }

        // =============================================
        // THEME / LANG
        // =============================================
        function toggleTheme() {
            isDark = !isDark;
            document.getElementById('themeIcon').textContent = isDark ? '🌙' : '☀️';
            document.getElementById('themeLabel').textContent = isDark ? 'DARK' : 'LIGHT';
            document.body.style.background = isDark ? '#0a0a0a' : '#1a1a2e';
        }

        function toggleLang() {
            currentLang = currentLang === 'en' ? 'fa' : 'en';
            document.getElementById('langIcon').textContent = currentLang === 'en' ? '🇺🇸' : '🇮🇷';
            document.getElementById('langLabel').textContent = currentLang === 'en' ? 'EN' : 'FA';
            // Update status badge
            const t = I18N[currentLang];
            const map = {
                'active': t.active,
                'paused': t.paused,
                'expired': t.expired,
                'limit': t.limit,
                'dailyLimit': t.dailyLimit
            };
            const s = map[STATUS_CODE] || t.active;
            statusBadge.textContent = `🟢 ${s.toUpperCase()}`;
            statusText.textContent = s.toUpperCase();
        }

        // =============================================
        // PARTICLES
        // =============================================
        (function createParticles() {
            const container = document.getElementById('particles');
            for (let i = 0; i < 30; i++) {
                const p = document.createElement('div');
                p.className = 'particle';
                p.style.left = Math.random() * 100 + '%';
                p.style.animationDuration = (Math.random() * 20 + 10) + 's';
                p.style.animationDelay = (Math.random() * 20) + 's';
                p.style.width = (Math.random() * 3 + 1) + 'px';
                p.style.height = p.style.width;
                p.style.background = `hsla(${Math.random() * 360}, 80%, 60%, 0.3)`;
                container.appendChild(p);
            }
        })();

        // =============================================
        // START
        // =============================================
        document.addEventListener('DOMContentLoaded', init);
    </script>

</body>
