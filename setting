                    status: 'active', expiry: '۱۴۰۴/۰۶/۱۰' }
            ],
            stats: {
                totalUsers: 12,
                activeUsers: 8,
                todayUsage: '2.4GB',
                totalUsage: '47.8GB'
            },
            system: {
                status: 'online',
                cpu: '12%',
                ram: '43%',
                uptime: '14 days',
                coreVersion: 'v1.8.4'
