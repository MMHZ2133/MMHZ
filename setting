<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>پنل اشتراک کاربری</title>
    <link href="https://fonts.googleapis.com/css2?family=Vazirmatn:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* =============================================
                   RESET & VARIABLES (مشابه Marzban)
                ============================================= */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg-primary: #0b0f19;
            --bg-card: rgba(17, 24, 39, 0.8);
            --bg-card-hover: rgba(31, 41, 55, 0.6);
            --bg-inner: rgba(31, 41, 55, 0.4);
            --border-color: rgba(99, 102, 241, 0.15);
            --border-hover: rgba(99, 102, 241, 0.3);
            --text-primary: #f9fafb;
            --text-secondary: #9ca3af;
            --text-muted: #6b7280;
            --accent-purple: #818cf8;
            --accent-blue: #4f46e5;
            --accent-green: #34d399;
            --accent-amber: #fbbf24;
            --accent-pink: #f472b6;
            --accent-red: #f87171;
            --shadow-card: 0 10px 30px rgba(0, 0, 0, 0.3);
            --radius: 16px;
            --radius-sm: 12px;
            --transition: all 0.3s ease;
        }

        body {
            font-family: 'Vazirmatn', sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
            direction: rtl;
            position: relative;
            overflow-x: hidden;
        }

        /* =============================================
                   BACKGROUND EFFECTS (مشابه Marzban)
                ============================================= */
        .bg-glow {
            position: fixed;
            border-radius: 50%;
            filter: blur(100px);
            pointer-events: none;
            z-index: 0;
        }

        .bg-glow-1 {
            width: 400px;
            height: 400px;
            background: rgba(99, 102, 241, 0.08);
            top: -100px;
            right: -100px;
        }

        .bg-glow-2 {
            width: 500px;
            height: 500px;
            background: rgba(52, 211, 153, 0.05);
            bottom: -200px;
            left: -200px;
        }

        /* =============================================
                   MAIN CONTAINER
                ============================================= */
        .container {
            max-width: 1100px;
            width: 100%;
            position: relative;
            z-index: 1;
        }

        /* =============================================
                   TOP BAR (مشابه Marzban)
                ============================================= */
        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            flex-wrap: wrap;
            gap: 12px;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .brand .icon {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, var(--accent-purple), var(--accent-blue));
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            color: #fff;
        }

        .brand .text {
            font-size: 20px;
            font-weight: 800;
            letter-spacing: -0.5px;
        }

        .brand .text span {
            color: var(--accent-purple);
        }

        .top-actions {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .btn-icon {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            color: var(--text-secondary);
            padding: 8px 14px;
            border-radius: var(--radius-sm);
            cursor: pointer;
            transition: var(--transition);
            font-family: inherit;
            font-size: 13px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .btn-icon:hover {
            background: var(--bg-card-hover);
            border-color: var(--border-hover);
            color: var(--text-primary);
        }

        .btn-icon i {
            font-size: 14px;
        }

        /* =============================================
                   USER PROFILE CARD (مشابه Marzban)
                ============================================= */
        .profile-card {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: var(--radius);
            padding: 28px 32px;
            backdrop-filter: blur(12px);
            margin-bottom: 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
            transition: var(--transition);
        }

        .profile-card:hover {
            border-color: var(--border-hover);
        }

        .profile-info {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .profile-avatar {
            width: 64px;
            height: 64px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--accent-purple), var(--accent-blue));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            font-weight: 800;
            color: #fff;
            flex-shrink: 0;
        }

        .profile-details h2 {
            font-size: 22px;
            font-weight: 800;
            margin-bottom: 2px;
        }

        .profile-details .sub {
            font-size: 13px;
            color: var(--text-muted);
            font-family: monospace;
            direction: ltr;
            text-align: left;
        }

        .profile-status {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .status-badge {
            padding: 6px 20px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .status-badge.active {
            background: rgba(52, 211, 153, 0.12);
            color: var(--accent-green);
            border: 1px solid rgba(52, 211, 153, 0.2);
        }

        .status-badge.expired {
            background: rgba(248, 113, 113, 0.12);
            color: var(--accent-red);
            border: 1px solid rgba(248, 113, 113, 0.2);
        }

        .status-badge.limited {
            background: rgba(251, 191, 36, 0.12);
            color: var(--accent-amber);
            border: 1px solid rgba(251, 191, 36, 0.2);
        }

        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            display: inline-block;
        }

        .status-dot.on {
            background: var(--accent-green);
            animation: pulse 2s infinite;
        }
        .status-dot.off {
            background: var(--accent-red);
        }
        .status-dot.warn {
            background: var(--accent-amber);
        }

        @keyframes pulse {
            0%,
            100% {
                opacity: 1;
                transform: scale(1);
            }
            50% {
                opacity: 0.5;
                transform: scale(0.9);
            }
        }

        /* =============================================
                   STATS GRID (مشابه Marzban Dashboard)
                ============================================= */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 16px;
            margin-bottom: 24px;
        }

        .stat-card {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: var(--radius);
            padding: 18px 22px;
            transition: var(--transition);
        }

        .stat-card:hover {
            border-color: var(--border-hover);
            transform: translateY(-2px);
        }

        .stat-card .label {
            font-size: 12px;
            color: var(--text-muted);
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .stat-card .label i {
            font-size: 14px;
            opacity: 0.6;
        }

        .stat-card .value {
            font-size: 26px;
            font-weight: 800;
            margin: 6px 0 2px;
        }

        .stat-card .sub-value {
            font-size: 13px;
            color: var(--text-secondary);
        }

        .stat-card .progress-bar {
            margin-top: 10px;
            height: 4px;
            background: rgba(255, 255, 255, 0.06);
            border-radius: 4px;
            overflow: hidden;
        }

        .stat-card .progress-bar .fill {
            height: 100%;
            border-radius: 4px;
            transition: width 0.8s ease;
        }

        .stat-card.purple .value {
            color: var(--accent-purple);
        }
        .stat-card.purple .fill {
            background: var(--accent-purple);
        }
        .stat-card.green .value {
            color: var(--accent-green);
        }
        .stat-card.green .fill {
            background: var(--accent-green);
        }
        .stat-card.amber .value {
            color: var(--accent-amber);
        }
        .stat-card.amber .fill {
            background: var(--accent-amber);
        }
        .stat-card.pink .value {
            color: var(--accent-pink);
        }
        .stat-card.pink .fill {
            background: var(--accent-pink);
        }

        /* =============================================
                   SUBSCRIPTION LINKS (مشابه 3x-ui)
                ============================================= */
        .links-section {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: var(--radius);
            padding: 24px;
            backdrop-filter: blur(12px);
            margin-bottom: 24px;
        }

        .links-section .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            flex-wrap: wrap;
            gap: 12px;
        }

        .links-section .header h3 {
            font-size: 18px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .links-section .header h3 i {
            color: var(--accent-purple);
        }

        .links-section .header .badge-recommended {
            background: var(--accent-purple);
            color: #fff;
            font-size: 10px;
            font-weight: 700;
            padding: 4px 12px;
            border-radius: 20px;
            letter-spacing: 0.5px;
        }

        /* ===== Universal Link ===== */
        .universal-link {
            background: var(--bg-inner);
            border: 1px solid var(--border-hover);
            border-radius: var(--radius-sm);
            padding: 16px 20px;
            margin-bottom: 16px;
            transition: var(--transition);
        }

        .universal-link:hover {
            border-color: var(--accent-purple);
        }

        .universal-link .label {
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .universal-link .link-box {
            display: flex;
            gap: 10px;
            align-items: center;
            flex-wrap: wrap;
        }

        .universal-link .link-box input {
            flex: 1;
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-sm);
            padding: 10px 16px;
            color: var(--text-primary);
            font-family: monospace;
            font-size: 13px;
            direction: ltr;
            text-align: left;
            outline: none;
            transition: var(--transition);
            min-width: 200px;
        }

        .universal-link .link-box input:focus {
            border-color: var(--accent-purple);
        }

        .universal-link .link-box .actions {
            display: flex;
            gap: 8px;
        }

        .btn-copy {
            background: var(--accent-purple);
            color: #fff;
            border: none;
            padding: 10px 18px;
            border-radius: var(--radius-sm);
            font-family: inherit;
            font-weight: 600;
            font-size: 13px;
            cursor: pointer;
            transition: var(--transition);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .btn-copy:hover {
            background: var(--accent-blue);
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(99, 102, 241, 0.3);
        }

        .btn-qr {
            background: var(--bg-inner);
            border: 1px solid var(--border-color);
            color: var(--text-secondary);
            padding: 10px 14px;
            border-radius: var(--radius-sm);
            cursor: pointer;
            transition: var(--transition);
            font-size: 16px;
        }

        .btn-qr:hover {
            border-color: var(--accent-purple);
            color: var(--text-primary);
        }

        /* ===== Format Grid ===== */
        .format-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 12px;
            margin-top: 16px;
        }

        .format-item {
            background: var(--bg-inner);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-sm);
            padding: 14px 16px;
            transition: var(--transition);
        }

        .format-item:hover {
            border-color: var(--border-hover);
            transform: translateY(-2px);
        }

        .format-item .top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
        }

        .format-item .top .name {
            font-size: 13px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .format-item .top .tag {
            font-size: 9px;
            font-weight: 700;
            text-transform: uppercase;
            padding: 2px 10px;
            border-radius: 20px;
            letter-spacing: 0.5px;
        }

        .tag.vless {
            background: rgba(99, 102, 241, 0.15);
            color: var(--accent-purple);
        }
        .tag.base64 {
            background: rgba(52, 211, 153, 0.15);
            color: var(--accent-green);
        }
        .tag.singbox {
            background: rgba(251, 191, 36, 0.15);
            color: var(--accent-amber);
        }
        .tag.clash {
            background: rgba(139, 92, 246, 0.15);
            color: #8b5cf6;
        }

        .format-item .link-box {
            display: flex;
            gap: 8px;
            align-items: center;
        }

        .format-item .link-box input {
            flex: 1;
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 8px 12px;
            color: var(--text-primary);
            font-family: monospace;
            font-size: 11px;
            direction: ltr;
            text-align: left;
            outline: none;
            min-width: 100px;
        }

        .format-item .link-box input:focus {
            border-color: var(--accent-purple);
        }

        .format-item .link-box .btn-sm {
            padding: 6px 12px;
            font-size: 12px;
            border-radius: 8px;
        }

        /* =============================================
                   ONE-CLICK IMPORTS (مشابه 3x-ui)
                ============================================= */
        .import-section {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: var(--radius);
            padding: 24px;
            backdrop-filter: blur(12px);
            margin-bottom: 24px;
        }

        .import-section .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
            flex-wrap: wrap;
            gap: 12px;
        }

        .import-section .header h3 {
            font-size: 16px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .import-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
            gap: 10px;
        }

        .import-btn {
            background: var(--bg-inner);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-sm);
            padding: 12px 16px;
            color: var(--text-secondary);
            text-decoration: none;
            text-align: center;
            transition: var(--transition);
            font-weight: 600;
            font-size: 13px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .import-btn:hover {
            background: var(--bg-card-hover);
            border-color: var(--border-hover);
            color: var(--text-primary);
            transform: translateY(-2px);
        }

        .import-btn i {
            font-size: 16px;
        }

        /* =============================================
                   EXPIRY & DETAILS (مشابه Marzban)
                ============================================= */
        .details-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 16px;
        }

        .detail-card {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: var(--radius);
            padding: 18px 22px;
            transition: var(--transition);
        }

        .detail-card:hover {
            border-color: var(--border-hover);
        }

        .detail-card .label {
            font-size: 11px;
            color: var(--text-muted);
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .detail-card .value {
            font-size: 18px;
            font-weight: 700;
            margin-top: 4px;
        }

        .detail-card .value.highlight {
            color: var(--accent-purple);
        }

        /* =============================================
                   TOAST NOTIFICATION
                ============================================= */
        .toast {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%) translateY(100px);
            background: var(--bg-card);
            border: 1px solid var(--border-hover);
            color: var(--text-primary);
            padding: 14px 28px;
            border-radius: var(--radius-sm);
            font-weight: 600;
            font-size: 14px;
            box-shadow: var(--shadow-card);
            backdrop-filter: blur(12px);
            z-index: 999;
            transition: all 0.5s ease;
            opacity: 0;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .toast.show {
            opacity: 1;
            transform: translateX(-50%) translateY(0);
        }

        .toast i {
            color: var(--accent-green);
            font-size: 18px;
        }

        /* =============================================
                   QR MODAL
                ============================================= */
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.7);
            backdrop-filter: blur(8px);
            z-index: 1000;
            display: none;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .modal-overlay.show {
            display: flex;
        }

        .modal-content {
            background: var(--bg-card);
            border: 1px solid var(--border-hover);
            border-radius: var(--radius);
            padding: 32px;
            max-width: 400px;
            width: 100%;
            text-align: center;
            animation: fadeIn 0.3s ease-out;
        }

        .modal-content h3 {
            font-size: 20px;
            font-weight: 700;
            margin-bottom: 16px;
        }

        .modal-content .qr-wrapper {
            background: #fff;
            padding: 16px;
            border-radius: var(--radius-sm);
            display: inline-block;
            margin-bottom: 16px;
        }

        .modal-content .qr-wrapper img {
            width: 200px;
            height: 200px;
            display: block;
        }

        .modal-content .link-text {
            font-family: monospace;
            font-size: 12px;
            color: var(--text-secondary);
            word-break: break-all;
            background: var(--bg-inner);
            padding: 12px 16px;
            border-radius: var(--radius-sm);
            margin-bottom: 16px;
            direction: ltr;
            text-align: left;
        }

        .modal-content .btn-close {
            background: var(--bg-inner);
            border: 1px solid var(--border-color);
            color: var(--text-secondary);
            padding: 10px 32px;
            border-radius: var(--radius-sm);
            font-family: inherit;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: var(--transition);
        }

        .modal-content .btn-close:hover {
            border-color: var(--accent-purple);
            color: var(--text-primary);
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: scale(0.95);
            }
            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        /* =============================================
                   RESPONSIVE
                ============================================= */
        @media (max-width: 768px) {
            .profile-card {
                flex-direction: column;
                align-items: flex-start;
                padding: 20px;
            }
            .profile-status {
                width: 100%;
                justify-content: flex-start;
            }
            .stats-grid {
                grid-template-columns: 1fr 1fr;
            }
            .links-section .header {
                flex-direction: column;
                align-items: flex-start;
            }
            .universal-link .link-box {
                flex-direction: column;
                align-items: stretch;
            }
            .universal-link .link-box .actions {
                justify-content: stretch;
            }
            .format-item .link-box {
                flex-direction: column;
                align-items: stretch;
            }
            .details-grid {
                grid-template-columns: 1fr 1fr;
            }
            .top-bar {
                flex-direction: column;
                align-items: stretch;
            }
            .top-actions {
                justify-content: stretch;
            }
            .btn-icon {
                flex: 1;
                justify-content: center;
            }
        }

        @media (max-width: 480px) {
            .stats-grid {
                grid-template-columns: 1fr;
            }
            .details-grid {
                grid-template-columns: 1fr;
            }
            .import-grid {
                grid-template-columns: 1fr 1fr;
            }
            .profile-info {
                flex-direction: column;
                align-items: flex-start;
                gap: 12px;
            }
            .profile-avatar {
                width: 50px;
                height: 50px;
                font-size: 22px;
            }
            .profile-details h2 {
                font-size: 18px;
            }
        }

        /* =============================================
                   SCROLLBAR
                ============================================= */
        ::-webkit-scrollbar {
            width: 4px;
            height: 4px;
        }
        ::-webkit-scrollbar-track {
            background: transparent;
        }
        ::-webkit-scrollbar-thumb {
            background: var(--accent-purple);
            border-radius: 4px;
        }
    </style>
</head>
<body>

    <!-- ===== BACKGROUND EFFECTS ===== -->
    <div class="bg-glow bg-glow-1"></div>
    <div class="bg-glow bg-glow-2"></div>

    <!-- ===== MAIN CONTAINER ===== -->
    <div class="container">

        <!-- ===== TOP BAR ===== -->
        <div class="top-bar">
            <div class="brand">
                <div class="icon">🚀</div>
                <div class="text">Xray<span>Panel</span></div>
            </div>
            <div class="top-actions">
                <button class="btn-icon" onclick="toggleTheme()">
                    <i class="fas fa-moon"></i>
                    <span id="theme-label">تاریک</span>
                </button>
                <button class="btn-icon" onclick="toggleLang()">
                    <i class="fas fa-globe"></i>
                    <span id="lang-label">FA</span>
                </button>
                <button class="btn-icon" onclick="window.location.reload();">
                    <i class="fas fa-sync-alt"></i>
