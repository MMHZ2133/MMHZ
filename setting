<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>__USER_NAME__ - Subscription Panel</title>
    <link href="https://fonts.googleapis.com/css2?family=Vazirmatn:wght@400;500;600;700;800;900&family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/gh/itsyebekhe/nahan@main/tailwindcss.js"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        fa: ['Vazirmatn', 'sans-serif'],
                        en: ['Inter', 'sans-serif'],
                    },
                }
            }
        }
    </script>
    <style>
        /* ===== CSS Variables ===== */
        :root {
            /* Light Theme - Black & Gold */
            --bg-body: #f8f5f0;
            --bg-card: #ffffff;
            --bg-card-hover: #ffffff;
            --bg-inner: #faf8f5;
            --bg-input: #f5f2ed;
            --border-card: #e8e0d8;
            --border-inner: #e8e0d8;
            --border-focus: rgba(212, 175, 55, 0.3);
            --text-primary: #1a1a1a;
            --text-secondary: #4a4a4a;
            --text-muted: #8a8a8a;
            --accent: #d4af37;
            --accent-light: rgba(212, 175, 55, 0.1);
            --accent-hover: #c4a030;
            --accent-gradient: linear-gradient(135deg, #d4af37, #f5d060);
            --shadow-card: 0 1px 3px rgba(0, 0, 0, 0.06);
            --shadow-hover: 0 4px 16px rgba(0, 0, 0, 0.08);
            
            /* Status Colors */
            --green: #2d7d46;
            --green-bg: #f0f7f2;
            --green-border: #d4e8d9;
            --amber: #b8860b;
            --amber-bg: #fdf8f0;
            --amber-border: #f5ead0;
            --red: #8b1a1a;
            --red-bg: #fdf0f0;
            --red-border: #f5d4d4;
            
            --progress-bg: #edebe8;
            --modal-overlay: rgba(0, 0, 0, 0.6);
            --modal-card: #ffffff;
            --radius: 12px;
            --radius-sm: 8px;
            --transition: 0.2s ease;
        }

        /* Dark Theme - Black & Gold */
        .dark {
            --bg-body: #0a0a0a;
            --bg-card: #1a1a1a;
            --bg-card-hover: #1a1a1a;
            --bg-inner: #222222;
            --bg-input: #0a0a0a;
            --border-card: #333333;
            --border-inner: #2a2a2a;
            --border-focus: rgba(212, 175, 55, 0.3);
            --text-primary: #f5f0eb;
            --text-secondary: #b0b0b0;
            --text-muted: #6a6a6a;
            --accent: #d4af37;
            --accent-light: rgba(212, 175, 55, 0.12);
            --accent-hover: #c4a030;
            --accent-gradient: linear-gradient(135deg, #d4af37, #f5d060);
            --shadow-card: 0 1px 3px rgba(0, 0, 0, 0.3);
            --shadow-hover: 0 4px 16px rgba(0, 0, 0, 0.4);
            
            --green: #5a9b6e;
            --green-bg: rgba(90, 155, 110, 0.12);
            --green-border: rgba(90, 155, 110, 0.2);
            --amber: #d4a030;
            --amber-bg: rgba(212, 160, 48, 0.12);
            --amber-border: rgba(212, 160, 48, 0.2);
            --red: #b55a5a;
            --red-bg: rgba(181, 90, 90, 0.12);
            --red-border: rgba(181, 90, 90, 0.2);
            
            --progress-bg: #2a2a2a;
            --modal-overlay: rgba(0, 0, 0, 0.85);
            --modal-card: #1a1a1a;
        }

        /* ===== Base ===== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', 'Vazirmatn', sans-serif;
            background: var(--bg-body);
            color: var(--text-primary);
            transition: background var(--transition), color var(--transition);
            min-height: 100vh;
            padding: 20px 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            -webkit-font-smoothing: antialiased;
        }

        [lang="fa"] body {
            font-family: 'Vazirmatn', sans-serif;
        }

        /* ===== Scrollbar ===== */
        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: var(--accent); border-radius: 10px; }

        /* ===== Container ===== */
        .container {
            width: 100%;
            max-width: 820px;
            position: relative;
            z-index: 1;
        }

        /* ===== Cards ===== */
        .card {
            background: var(--bg-card);
            border: 1px solid var(--border-card);
            border-radius: var(--radius);
            padding: 20px 24px;
            transition: all var(--transition);
            box-shadow: var(--shadow-card);
        }

        .card:hover {
            box-shadow: var(--shadow-hover);
        }

        .card-inner {
            background: var(--bg-inner);
            border: 1px solid var(--border-inner);
            border-radius: var(--radius-sm);
            padding: 14px 18px;
            transition: all var(--transition);
        }

        /* ===== Gold Accent Border ===== */
        .gold-border {
            position: relative;
        }

        .gold-border::before {
            content: '';
            position: absolute;
            inset: -1px;
            border-radius: var(--radius);
            padding: 1px;
            background: var(--accent-gradient);
            -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
            pointer-events: none;
            opacity: 0.3;
            transition: opacity 0.3s;
        }

        .gold-border:hover::before {
            opacity: 0.8;
        }

        /* ===== Typography ===== */
        .title {
            font-size: 20px;
            font-weight: 800;
            color: var(--text-primary);
        }

        .title-gold {
            color: var(--accent);
        }

        .subtitle {
            font-size: 13px;
            color: var(--text-secondary);
            font-weight: 500;
        }

        .label {
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-muted);
        }

        .label-gold {
            color: var(--accent);
            letter-spacing: 1.5px;
        }

        .value {
            font-size: 26px;
            font-weight: 800;
            color: var(--text-primary);
        }

        .value-gold {
            color: var(--accent);
        }

        .value-sm {
            font-size: 14px;
            font-weight: 600;
            color: var(--text-primary);
        }

        /* ===== Buttons ===== */
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            padding: 7px 16px;
            border-radius: var(--radius-sm);
            font-size: 11px;
            font-weight: 600;
            border: none;
            cursor: pointer;
            transition: all var(--transition);
            text-decoration: none;
            white-space: nowrap;
            background: var(--bg-inner);
            color: var(--text-secondary);
            border: 1px solid var(--border-inner);
        }

        .btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
        }

        .btn-primary {
            background: var(--accent-gradient);
            color: #1a1a1a;
            border: none;
            padding: 7px 18px;
            font-weight: 700;
        }

        .btn-primary:hover {
            box-shadow: 0 2px 16px rgba(212, 175, 55, 0.3);
            transform: translateY(-1px);
        }

        .btn-dark {
            background: var(--text-primary);
            color: var(--bg-body);
            border: none;
            padding: 7px 18px;
        }

        .btn-dark:hover {
            opacity: 0.85;
            transform: translateY(-1px);
        }

        .btn-icon {
            width: 34px;
            height: 34px;
            padding: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: var(--radius-sm);
            background: transparent;
            border: 1px solid var(--border-inner);
            color: var(--text-muted);
            transition: all var(--transition);
            cursor: pointer;
        }

        .btn-icon:hover {
            border-color: var(--accent);
            color: var(--accent);
            background: var(--accent-light);
        }

        /* ===== Input Group ===== */
        .input-group {
            display: flex;
            align-items: stretch;
            gap: 6px;
            background: var(--bg-input);
            border: 1px solid var(--border-inner);
            border-radius: var(--radius-sm);
            padding: 4px;
            transition: all var(--transition);
        }

        .input-group:focus-within {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px var(--border-focus);
        }

        .input-group input {
            flex: 1;
            min-width: 0;
            padding: 8px 12px;
            background: transparent;
            border: none;
            color: var(--text-primary);
            font-size: 12px;
            font-family: 'Inter', monospace;
            outline: none;
        }

        .input-group input::selection {
            background: var(--accent);
            color: #1a1a1a;
        }

        /* ===== Tags ===== */
        .tag {
            font-size: 9px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            padding: 2px 10px;
            border-radius: 4px;
            border: 1px solid var(--border-inner);
            background: var(--bg-inner);
            color: var(--text-muted);
            white-space: nowrap;
        }

        .tag-gold {
            background: var(--accent-light);
            color: var(--accent);
            border-color: rgba(212, 175, 55, 0.25);
        }

        .tag-dark {
            background: var(--text-primary);
            color: var(--bg-body);
            border-color: var(--text-primary);
        }

        /* ===== Status Badge ===== */
        .badge {
            display: inline-block;
            padding: 4px 14px;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 600;
            border: 1px solid var(--border-inner);
            background: var(--bg-inner);
            color: var(--text-secondary);
        }

        .badge-active {
            background: var(--green-bg);
            color: var(--green);
            border-color: var(--green-border);
        }

        .badge-paused {
            background: var(--amber-bg);
            color: var(--amber);
            border-color: var(--amber-border);
        }

        .badge-expired {
            background: var(--red-bg);
            color: var(--red);
            border-color: var(--red-border);
        }

        /* ===== Progress ===== */
        .progress {
            height: 4px;
            border-radius: 4px;
            background: var(--progress-bg);
            overflow: hidden;
            margin-top: 8px;
        }

        .progress-fill {
            height: 100%;
            border-radius: 4px;
            background: var(--accent-gradient);
            transition: width 0.8s ease;
        }

        /* ===== Avatar ===== */
        .avatar {
            width: 56px;
            height: 56px;
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--accent-light);
            border: 2px solid var(--accent);
            color: var(--accent);
            flex-shrink: 0;
        }

        .avatar svg {
            width: 28px;
            height: 28px;
        }

        /* ===== Grid ===== */
        .grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
        }

        .grid-4 {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 8px;
        }

        /* ===== Modal ===== */
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: var(--modal-overlay);
            backdrop-filter: blur(4px);
            -webkit-backdrop-filter: blur(4px);
            display: none;
            align-items: center;
            justify-content: center;
            padding: 24px;
            z-index: 100;
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .modal-overlay.show {
            display: flex;
            opacity: 1;
        }

        .modal-card {
            background: var(--modal-card);
            border: 1px solid var(--border-card);
            border-radius: var(--radius);
            padding: 28px;
            max-width: 380px;
            width: 100%;
            transform: scale(0.95);
            transition: transform 0.3s ease;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
            position: relative;
        }

        .modal-overlay.show .modal-card {
            transform: scale(1);
        }

        .modal-close {
            position: absolute;
            top: 14px;
            right: 14px;
            background: none;
            border: none;
            color: var(--text-muted);
            cursor: pointer;
            padding: 4px;
            border-radius: 4px;
            transition: all var(--transition);
        }

        .modal-close:hover {
            background: var(--bg-inner);
            color: var(--text-primary);
        }

        /* ===== Toast ===== */
        .toast {
            position: fixed;
            top: 24px;
            left: 50%;
            transform: translateX(-50%) translateY(-16px);
            background: var(--bg-card);
            border: 1px solid var(--border-card);
            border-radius: var(--radius-sm);
            padding: 10px 20px;
            box-shadow: var(--shadow-hover);
            font-size: 13px;
            font-weight: 600;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 10px;
            z-index: 200;
            opacity: 0;
            pointer-events: none;
            transition: all 0.4s ease;
        }

        .toast.show {
            opacity: 1;
            transform: translateX(-50%) translateY(0);
            pointer-events: auto;
        }

        .toast-icon {
            color: var(--accent);
            flex-shrink: 0;
        }

        /* ===== Gold Divider ===== */
        .divider-gold {
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--accent), transparent);
            margin: 14px 0;
            opacity: 0.3;
        }

        .divider {
            height: 1px;
            background: var(--border-inner);
            margin: 14px 0;
        }

        /* ===== Responsive ===== */
        @media (max-width: 768px) {
            body { padding: 14px 10px; }
            .card { padding: 16px 18px; }
            .grid-2 { grid-template-columns: 1fr; gap: 12px; }
            .grid-4 { grid-template-columns: repeat(2, 1fr); gap: 6px; }
            .value { font-size: 22px; }
            .title { font-size: 18px; }
            .avatar { width: 48px; height: 48px; }
            .avatar svg { width: 24px; height: 24px; }
            .modal-card { padding: 20px; margin: 16px; }
        }

        @media (max-width: 480px) {
            .grid-4 { grid-template-columns: 1fr 1fr; }
            .input-group input { font-size: 10px; padding: 6px 10px; }
            .btn { font-size: 10px; padding: 5px 12px; }
        }

        /* ===== Utility ===== */
        .flex { display: flex; }
        .flex-center { display: flex; align-items: center; justify-content: center; }
        .flex-between { display: flex; align-items: center; justify-content: space-between; }
        .gap-1 { gap: 6px; }
        .gap-2 { gap: 12px; }
        .gap-3 { gap: 16px; }
        .mt-1 { margin-top: 6px; }
        .mt-2 { margin-top: 12px; }
        .mt-3 { margin-top: 16px; }
        .mt-4 { margin-top: 24px; }
        .mb-1 { margin-bottom: 6px; }
        .mb-2 { margin-bottom: 12px; }
        .mb-3 { margin-bottom: 16px; }
        .text-center { text-align: center; }
        .text-right { text-align: right; }
        .w-full { width: 100%; }
        .relative { position: relative; }

        /* ===== Animations ===== */
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(16px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .animate-in {
            animation: fadeInUp 0.5s ease forwards;
        }

        .delay-1 { animation-delay: 0.05s; opacity: 0; }
        .delay-2 { animation-delay: 0.1s; opacity: 0; }
        .delay-3 { animation-delay: 0.15s; opacity: 0; }
        .delay-4 { animation-delay: 0.2s; opacity: 0; }

        /* ===== Gold Sparkle ===== */
        .sparkle {
            position: relative;
        }

        .sparkle::after {
            content: '✦';
            position: absolute;
            top: -4px;
            right: -6px;
            font-size: 8px;
            color: var(--accent);
            opacity: 0.5;
        }
    </style>
</head>
<body>

    <!-- ===== Toast ===== -->
    <div id="toast" class="toast">
        <svg class="toast-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 6L9 17l-5-5"/>
        </svg>
        <span id="toast-msg">Copied!</span>
    </div>

    <!-- ===== Modal ===== -->
    <div id="qr-modal" class="modal-overlay">
        <div class="modal-card">
            <button class="modal-close" onclick="closeQR()">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18"/>
                    <line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
            </button>
            <h3 class="title text-center mb-2" id="qr-title" style="color: var(--accent);">Scan QR</h3>
            <div class="flex-center">
                <img id="qr-img" src="" alt="QR Code" class="w-48 h-48 sm:w-52 sm:h-52" style="border-radius: 8px; background: white; padding: 8px;">
            </div>
            <p id="qr-text" class="text-center text-xs text-muted mt-3 break-all" style="font-family: monospace; font-size: 11px;"></p>
            <button onclick="closeQR()" class="btn btn-primary w-full mt-3">Close</button>
        </div>
    </div>

    <!-- ===== Main Container ===== -->
    <div class="container">

        <!-- ===== Header ===== -->
        <div class="card gold-border animate-in delay-1">
            <div class="flex-between">
                <div class="flex gap-2">
                    <div style="width: 36px; height: 36px; border-radius: var(--radius-sm); background: var(--accent-gradient); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                            <path d="M2 17l10 5 10-5"/>
                            <path d="M2 12l10 5 10-5"/>
                        </svg>
                    </div>
                    <div>
                        <div class="title"><span class="title-gold">✦</span> Panel</div>
                        <div class="subtitle">Subscription Manager</div>
                    </div>
                </div>
                <div class="flex gap-1">
                    <button onclick="toggleTheme()" class="btn" id="theme-btn">
                        <span id="theme-icon">🌙</span>
                        <span id="theme-label">Dark</span>
                    </button>
                    <button onclick="toggleLang()" class="btn" id="lang-btn">
                        <span id="lang-icon">🇺🇸</span>
                        <span id="lang-label">EN</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- ===== Profile ===== -->
        <div class="card gold-border animate-in delay-2 mt-2">
            <div class="flex" style="gap: 16px; flex-wrap: wrap;">
                <div class="avatar">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                        <circle cx="12" cy="7" r="4"/>
                    </svg>
                </div>
                <div style="flex: 1; min-width: 140px;">
                    <div class="title" style="font-size: 18px;">__USER_NAME__</div>
                    <div class="subtitle" style="font-size: 12px; font-family: monospace;">ID: __USER_ID__</div>
                    <div class="flex gap-2 mt-1" style="flex-wrap: wrap;">
                        <span id="status-badge" class="badge badge-active">Active</span>
                        <span class="subtitle" style="font-size: 11px;">Expires: <strong style="color: var(--text-primary);">__EXPIRY_DATE__</strong></span>
                    </div>
                </div>
                <div style="text-align: right; flex-shrink: 0;">
                    <div class="label label-gold">IP</div>
                    <div class="value-sm" style="font-family: monospace; font-size: 13px;" id="client-ip">—</div>
                </div>
            </div>
        </div>

        <!-- ===== Stats ===== -->
        <div class="grid-2 animate-in delay-3 mt-2">
            <div class="card gold-border">
                <div class="flex-between">
                    <span class="label label-gold" data-i18n="total">Total Usage</span>
                    <span class="subtitle" style="font-size: 11px;">/ __LIMIT_TOTAL_GB__ GB</span>
                </div>
                <div class="value value-gold mt-1">__TOTAL_GB__</div>
                __TOTAL_PROGRESS__
            </div>
            <div class="card gold-border">
                <div class="flex-between">
                    <span class="label label-gold" data-i18n="daily">Daily Usage</span>
                    <span class="subtitle" style="font-size: 11px;">/ __LIMIT_DAILY_GB__ GB</span>
                </div>
                <div class="value value-gold mt-1">__DAILY_GB__</div>
                __DAILY_PROGRESS__
            </div>
        </div>

        <!-- ===== Subscription ===== -->
        <div class="card gold-border animate-in delay-4 mt-2">
            <div class="flex-between mb-2">
                <div>
                    <div class="label label-gold" data-i18n="sub">Subscription URL</div>
                    <div class="subtitle" data-i18n="sub-desc">Import this link into your client</div>
                </div>
                <span class="tag tag-gold">✦ Premium</span>
            </div>

            <!-- Main -->
            <div class="input-group">
                <input type="text" id="link-main" value="__SYNC_NORMAL__" readonly>
                <button onclick="copyLink('link-main')" class="btn btn-primary">Copy</button>
                <button onclick="showQR('__SYNC_NORMAL__')" class="btn-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="7" height="7"/>
                        <rect x="14" y="3" width="7" height="7"/>
                        <rect x="3" y="14" width="7" height="7"/>
                        <line x1="14" y1="14" x2="14" y2="21"/>
                        <line x1="21" y1="14" x2="21" y2="21"/>
                        <line x1="14" y1="17" x2="21" y2="17"/>
                    </svg>
                </button>
            </div>

            <!-- Formats -->
            <div class="divider-gold"></div>

            <div class="label label-gold mb-2" data-i18n="formats">Formats</div>

            <div style="display: flex; flex-direction: column; gap: 6px;">
                <!-- Base64 -->
                <div class="flex" style="gap: 6px; align-items: center;">
                    <span class="tag tag-gold">Base64</span>
                    <div class="input-group" style="flex: 1;">
                        <input type="text" id="link-base64" value="__SYNC_NORMAL__" readonly>
                        <button onclick="copyLink('link-base64')" class="btn">Copy</button>
                        <button onclick="showQR(document.getElementById('link-base64').value)" class="btn-icon">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="3" width="7" height="7"/>
                                <rect x="14" y="3" width="7" height="7"/>
                                <rect x="3" y="14" width="7" height="7"/>
                                <line x1="14" y1="14" x2="14" y2="21"/>
                                <line x1="21" y1="14" x2="21" y2="21"/>
                                <line x1="14" y1="17" x2="21" y2="17"/>
                            </svg>
                        </button>
                    </div>
                </div>

                <!-- Clash -->
                <div class="flex" style="gap: 6px; align-items: center;">
                    <span class="tag tag-dark">Clash</span>
                    <div class="input-group" style="flex: 1;">
                        <input type="text" id="link-clash" value="__SYNC_NORMAL__" readonly>
                        <button onclick="copyLink('link-clash')" class="btn">Copy</button>
                        <button onclick="showQR(document.getElementById('link-clash').value)" class="btn-icon">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="3" width="7" height="7"/>
                                <rect x="14" y="3" width="7" height="7"/>
                                <rect x="3" y="14" width="7" height="7"/>
                                <line x1="14" y1="14" x2="14" y2="21"/>
                                <line x1="21" y1="14" x2="21" y2="21"/>
                                <line x1="14" y1="17" x2="21" y2="17"/>
                            </svg>
                        </button>
                    </div>
                </div>

                <!-- Sing-box -->
                <div class="flex" style="gap: 6px; align-items: center;">
                    <span class="tag" style="background: var(--amber-bg); color: var(--amber); border-color: var(--amber-border);">Sing-box</span>
                    <div class="input-group" style="flex: 1;">
                        <input type="text" id="link-singbox" value="__SYNC_NORMAL__" readonly>
                        <button onclick="copyLink('link-singbox')" class="btn">Copy</button>
                        <button onclick="showQR(document.getElementById('link-singbox').value)" class="btn-icon">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="3" width="7" height="7"/>
                                <rect x="14" y="3" width="7" height="7"/>
                                <rect x="3" y="14" width="7" height="7"/>
                                <line x1="14" y1="14" x2="14" y2="21"/>
                                <line x1="21" y1="14" x2="21" y2="21"/>
                                <line x1="14" y1="17" x2="21" y2="17"/>
                            </svg>
                        </button>
                    </div>
                </div>

                <!-- Raw -->
                <div class="flex" style="gap: 6px; align-items: center;">
                    <span class="tag" style="background: var(--red-bg); color: var(--red); border-color: var(--red-border);">Raw</span>
                    <div class="input-group" style="flex: 1;">
                        <input type="text" id="link-raw" value="__SYNC_NORMAL__" readonly>
                        <button onclick="copyLink('link-raw')" class="btn">Copy</button>
                        <button onclick="showQR(document.getElementById('link-raw').value)" class="btn-icon">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="3" width="7" height="7"/>
                                <rect x="14" y="3" width="7" height="7"/>
                                <rect x="3" y="14" width="7" height="7"/>
                                <line x1="14" y1="14" x2="14" y2="21"/>
                                <line x1="21" y1="14" x2="21" y2="21"/>
                                <line x1="14" y1="17" x2="21" y2="17"/>
                            </svg>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== One-Click ===== -->
        <div class="card gold-border mt-2 animate-in delay-4">
            <div class="label label-gold mb-1" data-i18n="oneclick">One-Click Import</div>
            <div class="subtitle mb-2" data-i18n="oneclick-desc">Quick import for supported clients</div>
            <div class="grid-4">
                <a id="v2rayng-link" href="#" class="btn" style="justify-content: center; gap: 6px; border-color: var(--accent);">
                    <span style="font-size: 10px; font-weight: 700;">v2rayNG</span>
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M7 7h10v10"/>
                        <path d="M7 17L17 7"/>
                    </svg>
                </a>
                <a href="#" onclick="window.location.href='v2rayn://install-sub?url='+encodeURIComponent('__SYNC_NORMAL__')+'&name=__USER_NAME__'" class="btn" style="justify-content: center; gap: 6px; border-color: var(--accent);">
                    <span style="font-size: 10px; font-weight: 700;">v2rayN</span>
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M7 7h10v10"/>
                        <path d="M7 17L17 7"/>
                    </svg>
                </a>
                <a href="#" onclick="window.location.href='shadowrocket://add/sub://'+btoa('__SYNC_NORMAL__')+'?title=__USER_NAME__'" class="btn" style="justify-content: center; gap: 6px; border-color: var(--accent);">
                    <span style="font-size: 10px; font-weight: 700;">Shadowrocket</span>
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M7 7h10v10"/>
                        <path d="M7 17L17 7"/>
                    </svg>
                </a>
                <a href="#" onclick="window.location.href='streisand://import/__SYNC_NORMAL__'" class="btn" style="justify-content: center; gap: 6px; border-color: var(--accent);">
                    <span style="font-size: 10px; font-weight: 700;">Streisand</span>
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M7 7h10v10"/>
                        <path d="M7 17L17 7"/>
                    </svg>
                </a>
            </div>
        </div>

        <!-- ===== Footer ===== -->
        <div class="text-center mt-4">
            <span class="subtitle" style="font-size: 11px; letter-spacing: 1px;">
                <span class="title-gold">✦</span> Panel <span class="title-gold">✦</span> &bull; <span id="footer-year">2024</span>
            </span>
        </div>

    </div>

    <script>
        // ============================================================
        // I18N
        // ============================================================
        const I18N = {
            en: {
                total: 'Total Usage',
                daily: 'Daily Usage',
                sub: 'Subscription URL',
                'sub-desc': 'Import this link into your client',
                formats: 'Formats',
                oneclick: 'One-Click Import',
                'oneclick-desc': 'Quick import for supported clients',
                copied: 'Copied!',
                qr: 'Scan QR',
                close: 'Close',
                active: 'Active',
                paused: 'Paused',
                expired: 'Expired',
                limit: 'Limit Exceeded',
                dailylimit: 'Daily Limit Exceeded'
            },
            fa: {
                total: 'مصرف کل',
                daily: 'مصرف روزانه',
                sub: 'لینک اشتراک',
                'sub-desc': 'این لینک را در کلاینت خود وارد کنید',
                formats: 'فرمت‌ها',
                oneclick: 'وارد کردن سریع',
                'oneclick-desc': 'وارد کردن سریع برای کلاینت‌های پشتیبانی شده',
                copied: 'کپی شد!',
                qr: 'اسکن QR',
                close: 'بستن',
                active: 'فعال',
                paused: 'متوقف',
                expired: 'منقضی',
                limit: 'از حد مجاز رد شده',
                dailylimit: 'از حد روزانه رد شده'
            }
        };

        // ============================================================
        // State
        // ============================================================
        let lang = 'en';
        let dark = true;

        // ============================================================
        // DOM Ref
        // ============================================================
        const $ = id => document.getElementById(id);
        const qs = (sel, ctx) => (ctx || document).querySelector(sel);
        const qsa = (sel, ctx) => (ctx || document).querySelectorAll(sel);

        // ============================================================
        // Theme
        // ============================================================
        function applyTheme() {
            const root = document.documentElement;
            const icon = $('theme-icon');
            const label = $('theme-label');

            if (dark) {
                root.classList.add('dark');
                icon.textContent = '☀️';
                label.textContent = lang === 'fa' ? 'روشن' : 'Light';
            } else {
                root.classList.remove('dark');
                icon.textContent = '🌙';
                label.textContent = lang === 'fa' ? 'تاریک' : 'Dark';
            }
            try { localStorage.setItem('sp-theme', dark ? 'dark' : 'light'); } catch (_) {}
        }

        function toggleTheme() {
            dark = !dark;
            applyTheme();
        }

        // ============================================================
        // Language
        // ============================================================
        function applyLang() {
            const t = I18N[lang];
            qsa('[data-i18n]').forEach(el => {
                const key = el.getAttribute('data-i18n');
                if (t[key] !== undefined) el.textContent = t[key];
            });

            const icon = $('lang-icon');
            const label = $('lang-label');
            const html = document.documentElement;

            if (lang === 'fa') {
                html.setAttribute('dir', 'rtl');
                html.setAttribute('lang', 'fa');
                icon.textContent = '🇮🇷';
                label.textContent = 'FA';
            } else {
                html.setAttribute('dir', 'ltr');
                html.setAttribute('lang', 'en');
                icon.textContent = '🇺🇸';
                label.textContent = 'EN';
            }

            updateBadge();
            try { localStorage.setItem('sp-lang', lang); } catch (_) {}
        }

        function toggleLang() {
            lang = lang === 'en' ? 'fa' : 'en';
            applyLang();
            applyTheme();
        }

        // ============================================================
        // Badge
        // ============================================================
        function updateBadge() {
            const badge = $('status-badge');
            if (!badge) return;
            const t = I18N[lang];
            const code = '__STATUS_CODE__';
            const map = {
                active: { text: t.active || 'Active', cls: 'badge-active' },
                paused: { text: t.paused || 'Paused', cls: 'badge-paused' },
                expired: { text: t.expired || 'Expired', cls: 'badge-expired' },
                limit: { text: t.limit || 'Limit Exceeded', cls: 'badge-expired' },
                dailylimit: { text: t.dailylimit || 'Daily Limit Exceeded', cls: 'badge-expired' }
            };
            const s = map[code] || map.active;
            badge.textContent = s.text;
            badge.className = 'badge ' + s.cls;
        }

        // ============================================================
        // Toast
        // ============================================================
        let toastTimer = null;

        function showToast(msg) {
            const el = $('toast');
            const text = $('toast-msg');
            if (!el || !text) return;
            text.textContent = msg || I18N[lang].copied || 'Copied!';
            el.classList.add('show');
            clearTimeout(toastTimer);
            toastTimer = setTimeout(() => el.classList.remove('show'), 2000);
        }

        // ============================================================
        // Copy
        // ============================================================
        function copyLink(id) {
            const el = $(id);
            if (!el) return;
            el.select();
            el.setSelectionRange(0, 99999);
            try {
                navigator.clipboard.writeText(el.value).then(() => showToast());
            } catch (_) {
                document.execCommand('copy');
                showToast();
            }
        }

        // ============================================================
        // QR
        // ============================================================
        function showQR(url) {
            const modal = $('qr-modal');
            const img = $('qr-img');
            const text = $('qr-text');
            const title = $('qr-title');
            if (!modal || !img || !text) return;

            title.textContent = I18N[lang].qr || 'Scan QR';
            text.textContent = url;
            img.src = 'https://api.qrserver.com/v1/create-qr-code/?size=300x300&data=' + encodeURIComponent(url);

            modal.classList.add('show');
            document.body.style.overflow = 'hidden';
        }

        function closeQR() {
            const modal = $('qr-modal');
            if (!modal) return;
            modal.classList.remove('show');
            document.body.style.overflow = '';
        }

        document.addEventListener('click', (e) => {
            const modal = $('qr-modal');
            if (e.target === modal) closeQR();
        });

        // ============================================================
        // Init
        // ============================================================
        (function init() {
            try {
                const savedTheme = localStorage.getItem('sp-theme');
                if (savedTheme) dark = savedTheme === 'dark';
            } catch (_) {}
            try {
                const savedLang = localStorage.getItem('sp-lang');
                if (savedLang && I18N[savedLang]) lang = savedLang;
            } catch (_) {}

            applyTheme();
            applyLang();

            const year = $('footer-year');
            if (year) year.textContent = new Date().getFullYear();

            const main = $('link-main');
            if (main) {
                const base = main.value;
                const hasQuery = base.includes('?');
                const q = hasQuery ? '&' : '?';

                const setVal = (id, flag) => {
                    const el = $(id);
                    if (el) el.value = base + q + 'flag=' + flag;
                };

                setVal('link-base64', 'base64');
                setVal('link-clash', 'clash');
                setVal('link-singbox', 'singbox');
                setVal('link-raw', 'raw');

                const v2 = $('v2rayng-link');
                if (v2) {
                    const base64Url = base + q + 'flag=base64';
                    v2.href = 'v2rayng://install-sub?url=' + encodeURIComponent(base64Url) + '&name=' + encodeURIComponent('__USER_NAME__');
                }
            }

            fetch('https://api.ipify.org?format=json')
                .then(r => r.json())
                .then(data => {
                    const ip = $('client-ip');
                    if (ip) ip.textContent = data.ip || '—';
                })
                .catch(() => {
                    const ip = $('client-ip');
                    if (ip) ip.textContent = '—';
                });
        })();
    </script>

</body>
