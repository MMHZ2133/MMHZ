    <script>
        // ============================================================
        // I18N
        // ============================================================
        const I18N = {
            en: {
                copied: 'Copied!',
                copiedAll: 'All links copied!',
                qr: 'Scan QR',
                close: 'Close'
            },
            fa: {
                copied: 'کپی شد!',
                copiedAll: 'همه لینک‌ها کپی شد!',
                qr: 'اسکن QR',
                close: 'بستن'
            }
        };

        let lang = 'en';

        // ============================================================
        // DOM Ref
        // ============================================================
        const $ = id => document.getElementById(id);
        const qsa = (sel, ctx) => (ctx || document).querySelectorAll(sel);

        // ============================================================
        // Toast
        // ============================================================
        let toastTimer = null;

        function showToast(msg) {
            const el = $('toast');
            const text = $('toast-msg');
            if (!el || !text) return;
            text.textContent = msg || I18N[lang].copied || 'Copied!';
            el.classList.add('show');
            clearTimeout(toastTimer);
            toastTimer = setTimeout(() => el.classList.remove('show'), 2000);
        }

        // ============================================================
        // Copy
        // ============================================================
        function copyLink(id) {
            const el = $(id);
            if (!el) return;
            el.select();
            el.setSelectionRange(0, 99999);
            try {
                navigator.clipboard.writeText(el.value).then(() => showToast());
            } catch (_) {
                document.execCommand('copy');
                showToast();
            }
        }

        function copyAllLinks() {
            const links = [
                $('link-base64'),
                $('link-clash'),
                $('link-singbox'),
                $('link-raw'),
                $('link-shadowrocket')
            ];
            
            const allText = links
                .filter(el => el !== null)
                .map(el => el.value)
                .join('\n');
            
            try {
                navigator.clipboard.writeText(allText).then(() => {
                    showToast(I18N[lang].copiedAll || 'All links copied!');
                });
            } catch (_) {
                const textarea = document.createElement('textarea');
                textarea.value = allText;
                document.body.appendChild(textarea);
                textarea.select();
                document.execCommand('copy');
                document.body.removeChild(textarea);
                showToast(I18N[lang].copiedAll || 'All links copied!');
            }
        }

        // ============================================================
        // QR
        // ============================================================
        function showQR(url) {
            const modal = $('qr-modal');
            const img = $('qr-img');
            const text = $('qr-text');
            const title = $('qr-title');
            if (!modal || !img || !text) return;

            title.textContent = I18N[lang].qr || 'Scan QR';
            text.textContent = url;
            img.src = 'https://api.qrserver.com/v1/create-qr-code/?size=300x300&data=' + encodeURIComponent(url);

            modal.classList.add('show');
            document.body.style.overflow = 'hidden';
        }

        function closeQR() {
            const modal = $('qr-modal');
            if (!modal) return;
            modal.classList.remove('show');
            document.body.style.overflow = '';
        }

        document.addEventListener('click', (e) => {
            const modal = $('qr-modal');
            if (e.target === modal) closeQR();
        });

        // ============================================================
        // Status Badge
        // ============================================================
        function updateBadge() {
            const badge = $('status-badge');
            if (!badge) return;
            const code = '__STATUS_CODE__';
            const map = {
                active: { text: 'Active', cls: 'badge-active' },
                paused: { text: 'Paused', cls: 'badge-paused' },
                expired: { text: 'Expired', cls: 'badge-expired' },
                limit: { text: 'Limit Exceeded', cls: 'badge-expired' },
                dailylimit: { text: 'Daily Limit Exceeded', cls: 'badge-expired' }
            };
            const s = map[code] || map.active;
            badge.textContent = s.text;
            badge.className = 'badge ' + s.cls;
        }

        // ============================================================
        // Init
        // ============================================================
        (function init() {
            // Set year
            const year = $('footer-year');
            if (year) year.textContent = new Date().getFullYear();

            // Set status badge
            updateBadge();

            // Get base link
            const mainLink = '__SYNC_NORMAL__';
            const hasQuery = mainLink.includes('?');
            const q = hasQuery ? '&' : '?';

            // Set format links with proper flags
            const setVal = (id, flag) => {
                const el = $(id);
                if (el) el.value = mainLink + q + 'flag=' + flag;
            };

            setVal('link-base64', 'base64');
            setVal('link-clash', 'clash');
            setVal('link-singbox', 'singbox');
            setVal('link-raw', 'raw');
            
            // Shadowrocket uses base64
            const srEl = $('link-shadowrocket');
            if (srEl) srEl.value = mainLink + q + 'flag=base64';

            // Set v2rayNG link with base64 flag
            const v2 = $('v2rayng-link');
            if (v2) {
                const base64Url = mainLink + q + 'flag=base64';
                v2.href = 'v2rayng://install-sub?url=' + encodeURIComponent(base64Url) + '&name=' + encodeURIComponent('__USER_NAME__');
            }

            // Fetch IP
            fetch('https://api.ipify.org?format=json')
                .then(r => r.json())
                .then(data => {
                    const ip = $('client-ip');
                    if (ip) ip.textContent = data.ip || '—';
                })
                .catch(() => {
                    const ip = $('client-ip');
                    if (ip) ip.textContent = '—';
                });
        })();
    </script>

