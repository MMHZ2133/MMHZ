<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MMHZ پنل | اشتراک</title>
    <link href="https://fonts.googleapis.com/css2?family=Vazirmatn:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Vazirmatn', sans-serif;
            background: #0a0a0a;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 16px;
            direction: rtl;
        }

        /* ===== GLASS CARD ===== */
        .card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 24px;
            padding: 24px 20px;
            max-width: 400px;
            width: 100%;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.8), inset 0 1px 0 rgba(255, 255, 255, 0.03);
            transition: all 0.3s;
        }

        /* ===== HEADER ===== */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .logo-icon {
            width: 32px;
            height: 32px;
            background: linear-gradient(135deg, #818cf8, #4f46e5);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            color: #fff;
        }

        .logo-text {
            font-size: 16px;
            font-weight: 800;
            color: #fff;
            letter-spacing: -0.5px;
        }

        .logo-text span {
            color: #818cf8;
        }

        .status-badge {
            font-size: 12px;
            font-weight: 700;
            color: #34d399;
            background: rgba(52, 211, 153, 0.12);
            border: 1px solid rgba(52, 211, 153, 0.2);
            padding: 4px 14px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .status-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #34d399;
            display: inline-block;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.3; }
        }

        /* ===== USERNAME ===== */
        .username {
            font-size: 20px;
            font-weight: 800;
            color: #fff;
            margin-bottom: 2px;
        }

        .user-id {
            font-size: 11px;
            color: rgba(255, 255, 255, 0.25);
            font-weight: 500;
            direction: ltr;
            text-align: left;
        }

        /* ===== DIVIDER ===== */
        .divider {
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.06), transparent);
            margin: 14px 0;
        }

        /* ===== STATS GRID ===== */
        .stats-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-bottom: 14px;
        }

        .stat-item {
            background: rgba(255, 255, 255, 0.02);
            border-radius: 14px;
            padding: 12px 14px;
            border: 1px solid rgba(255, 255, 255, 0.03);
            transition: all 0.3s;
        }

        .stat-item:hover {
            background: rgba(255, 255, 255, 0.04);
            border-color: rgba(255, 255, 255, 0.06);
        }

        .stat-label {
            font-size: 10px;
            font-weight: 600;
            color: rgba(255, 255, 255, 0.3);
            margin-bottom: 2px;
        }

        .stat-value {
            font-size: 16px;
            font-weight: 700;
            color: #fff;
            letter-spacing: -0.3px;
        }

        .stat-value.green { color: #34d399; }
        .stat-value.blue { color: #818cf8; }
        .stat-value.amber { color: #fbbf24; }
        .stat-value.pink { color: #f472b6; }

        /* ===== PROGRESS ===== */
        .progress-section {
            margin: 10px 0 14px;
        }

        .progress-header {
            display: flex;
            justify-content: space-between;
            font-size: 12px;
            font-weight: 600;
            color: rgba(255, 255, 255, 0.4);
            margin-bottom: 6px;
        }

        .progress-header .used {
            color: #818cf8;
        }

        .progress-bar {
            width: 100%;
            height: 6px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 10px;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            border-radius: 10px;
            background: linear-gradient(90deg, #818cf8, #4f46e5);
            transition: width 0.8s ease;
        }

        /* ===== INFO ROW ===== */
        .info-row {
            display: flex;
            justify-content: space-between;
            padding: 5px 0;
            font-size: 12px;
        }

        .info-row .label {
            color: rgba(255, 255, 255, 0.3);
            font-weight: 500;
        }

        .info-row .value {
            color: rgba(255, 255, 255, 0.7);
            font-weight: 600;
            direction: ltr;
            text-align: left;
        }

        .info-row .value.highlight {
            color: #818cf8;
        }

        /* ===== BOTTOM STATUS ===== */
        .bottom-status {
            background: rgba(255, 255, 255, 0.02);
            border-radius: 14px;
            padding: 12px 16px;
            margin-top: 14px;
            border: 1px solid rgba(255, 255, 255, 0.03);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 6px;
        }

        .bottom-status .bot-name {
            font-size: 13px;
            font-weight: 700;
            color: #fff;
        }

        .bottom-status .bot-name span {
            color: #818cf8;
        }

        .bottom-status .usage-info {
            font-size: 12px;
            font-weight: 600;
            color: rgba(255, 255, 255, 0.4);
            direction: ltr;
        }

        .bottom-status .usage-info .remain {
            color: #34d399;
        }

        .bottom-status .usage-info .expiry {
            color: #f472b6;
        }

        /* ===== VLESS LINK ===== */
        .vless-box {
            background: rgba(255, 255, 255, 0.02);
            border-radius: 14px;
            padding: 12px 16px;
            margin-top: 12px;
            border: 1px solid rgba(255, 255, 255, 0.03);
        }

        .vless-box .label {
            font-size: 10px;
            font-weight: 600;
            color: rgba(255, 255, 255, 0.2);
            margin-bottom: 4px;
        }

        .vless-box .link {
            font-size: 11px;
            color: rgba(255, 255, 255, 0.4);
            font-family: monospace;
            word-break: break-all;
            direction: ltr;
            text-align: left;
            line-height: 1.6;
        }

        /* ===== GLOW ===== */
        .glow {
            position: fixed;
            border-radius: 50%;
            filter: blur(80px);
            pointer-events: none;
            z-index: -1;
        }

        .glow-1 {
            width: 300px;
            height: 300px;
            background: rgba(129, 140, 248, 0.08);
            top: -100px;
            right: -100px;
        }

        .glow-2 {
            width: 400px;
            height: 400px;
            background: rgba(52, 211, 153, 0.05);
            bottom: -150px;
            left: -150px;
        }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 420px) {
            .card { padding: 18px 14px; }
            .stats-grid { gap: 8px; }
            .stat-item { padding: 10px 12px; }
            .stat-value { font-size: 14px; }
            .bottom-status { flex-direction: column; align-items: flex-start; }
        }
    </style>
</head>
<body>

    <!-- ===== GLOW ===== -->
    <div class="glow glow-1"></div>
    <div class="glow glow-2"></div>

    <!-- ===== CARD ===== -->
    <div class="card">

        <!-- HEADER -->
        <div class="header">
            <div class="logo">
                <div class="logo-icon">📡</div>
                <div class="logo-text">MMHZ<span>Panel</span></div>
            </div>
            <span class="status-badge" id="statusBadge">
                <span class="status-dot"></span> فعال
            </span>
        </div>

        <!-- USER -->
        <div class="username" id="userName">Sanaei</div>
        <div class="user-id" id="userId">شناسه: 152y5rt1mjwh94ny</div>

        <div class="divider"></div>

        <!-- STATS -->
        <div class="stats-grid">
            <div class="stat-item">
                <div class="stat-label">آپلود</div>
                <div class="stat-value blue" id="upload">43.35MB</div>
            </div>
            <div class="stat-item">
                <div class="stat-label">دانلود</div>
                <div class="stat-value green" id="download">481.31MB</div>
            </div>
            <div class="stat-item">
                <div class="stat-label">مصرف</div>
                <div class="stat-value amber" id="usage">524.66MB</div>
            </div>
            <div class="stat-item">
                <div class="stat-label">سهمیه کل</div>
                <div class="stat-value pink" id="totalQuota">1.00GB</div>
            </div>
        </div>

        <!-- PROGRESS -->
        <div class="progress-section">
            <div class="progress-header">
                <span>میزان مصرف</span>
                <span class="used" id="percentText">52%</span>
            </div>
            <div class="progress-bar">
                <div class="progress-fill" id="progressFill" style="width:52%;"></div>
            </div>
        </div>

        <!-- INFO -->
        <div class="info-row">
            <span class="label">باقیمانده</span>
            <span class="value highlight" id="remained">499.34MB</span>
        </div>
        <div class="info-row">
            <span class="label">آخرین آنلاین</span>
            <span class="value" id="lastOnline">۶/۶/۲۰۲۴، ۱۰:۱۴:۱۸ ب.ظ</span>
        </div>
        <div class="info-row">
            <span class="label">انقضا</span>
            <span class="value" id="expiry">۶/۶/۲۰۲۴، ۱۰:۱۴:۱۸ ب.ظ</span>
        </div>

        <!-- BOTTOM STATUS -->
        <div class="bottom-status">
            <div class="bot-name"><span>G</span>NeshanVpnBot125</div>
            <div class="usage-info">
                <span class="remain">-499.34MB</span>
                <span class="expiry"> -29D,13H</span>
            </div>
        </div>

        <!-- VLESS LINK -->
        <div class="vless-box">
            <div class="label">🔗 لینک اشتراک</div>
            <div class="link" id="vlessLink">vless://50a592ee-404d-424b-b758-4e98389c4090@iran2.imsurn.ir:25539?encryption=none&headerType=http&host=nobi...</div>
        </div>

    </div>

    <script>
        // =============================================
        // 🚀 اینجا رو با داده‌های واقعی پر کن!
        // =============================================
        const userData = {
            name: 'Sanaei',
            id: '152y5rt1mjwh94ny',
            status: 'active', // active | paused | expired | limit
            download: '481.31MB',
            upload: '43.35MB',
            usage: '524.66MB',
            totalQuota: '1.00GB',
            remained: '499.34MB',
            percent: 52, // عدد بین 0 تا 100
            lastOnline: '۶/۶/۲۰۲۴، ۱۰:۱۴:۱۸ ب.ظ',
            expiry: '۶/۶/۲۰۲۴، ۱۰:۱۴:۱۸ ب.ظ',
            botName: 'GNeshanVpnBot125',
            remainTime: '-499.34MB',
            expiryTime: '-29D,13H',
            vless: 'vless://50a592ee-404d-424b-b758-4e98389c4090@iran2.imsurn.ir:25539?encryption=none&headerType=http&host=nobi...'
        };

        // =============================================
        // نمایش داده‌ها
        // =============================================
        document.getElementById('userName').textContent = userData.name;
        document.getElementById('userId').textContent = 'شناسه: ' + userData.id;

        // وضعیت
        const statusMap = {
            active: { text: 'فعال', color: '#34d399' },
            paused: { text: 'متوقف', color: '#fbbf24' },
            expired: { text: 'منقضی', color: '#f87171' },
            limit: { text: 'رد شده', color: '#f87171' }
        };
        const s = statusMap[userData.status] || statusMap.active;
        document.getElementById('statusBadge').innerHTML = `<span class="status-dot"></span> ${s.text}`;
        document.getElementById('statusBadge').style.color = s.color;
        document.getElementById('statusBadge').style.borderColor = s.color + '33';
        document.querySelector('.status-dot').style.background = s.color;

        // آمار
        document.getElementById('download').textContent = userData.download;
        document.getElementById('upload').textContent = userData.upload;
        document.getElementById('usage').textContent = userData.usage;
        document.getElementById('totalQuota').textContent = userData.totalQuota;
        document.getElementById('remained').textContent = userData.remained;
        document.getElementById('percentText').textContent = userData.percent + '%';
        document.getElementById('progressFill').style.width = Math.min(100, userData.percent) + '%';
        document.getElementById('lastOnline').textContent = userData.lastOnline;
        document.getElementById('expiry').textContent = userData.expiry;

        // لینک
        document.getElementById('vlessLink').textContent = userData.vless;

        // فوتر
        document.querySelector('.bot-name').innerHTML = 
            `<span>${userData.botName.replace(/[0-9]/g, '')}</span>${userData.botName.match(/[0-9]/g)?.join('') || ''}`;
        document.querySelector('.usage-info').innerHTML = 
            `<span class="remain">${userData.remainTime}</span> <span class="expiry">${userData.expiryTime}</span>`;
    </script>

</body>
</html>
