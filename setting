<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>__USER_NAME__ - Subscription Panel</title>
    <link href="https://fonts.googleapis.com/css2?family=Vazirmatn:wght@400;500;600;700;800;900&family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        /* ===== Reset & Base ===== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg-primary: #0d0d0d;
            --bg-card: #1a1a1a;
            --bg-card-hover: #242424;
            --bg-input: #0d0d0d;
            --border-color: #2a2a2a;
            --border-hover: #d4af37;
            --text-primary: #ffffff;
            --text-secondary: #aaaaaa;
            --text-muted: #666666;
            --gold: #d4af37;
            --gold-light: #f5d060;
            --gold-gradient: linear-gradient(135deg, #d4af37, #f5d060);
            --shadow-card: 0 4px 20px rgba(0, 0, 0, 0.5);
            --shadow-hover: 0 8px 32px rgba(212, 175, 55, 0.1);
            --radius: 12px;
            --radius-sm: 8px;
            --transition: 0.3s ease;
        }

        body {
            font-family: 'Inter', 'Vazirmatn', sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            min-height: 100vh;
            padding: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            background-image: 
                radial-gradient(ellipse at 20% 50%, rgba(212, 175, 55, 0.03) 0%, transparent 60%),
                radial-gradient(ellipse at 80% 50%, rgba(212, 175, 55, 0.03) 0%, transparent 60%);
        }

        [lang="fa"] body {
            font-family: 'Vazirmatn', sans-serif;
        }

        /* ===== Container ===== */
        .container {
            width: 100%;
            max-width: 860px;
            position: relative;
            z-index: 1;
        }

        /* ===== Cards ===== */
        .card {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: var(--radius);
            padding: 24px 28px;
            transition: all var(--transition);
            box-shadow: var(--shadow-card);
            margin-bottom: 16px;
        }

        .card:hover {
            border-color: var(--border-hover);
            box-shadow: var(--shadow-hover);
        }

        /* ===== Gold Border Accent ===== */
        .gold-border {
            position: relative;
        }

        .gold-border::before {
            content: '';
            position: absolute;
            inset: -1px;
            border-radius: var(--radius);
            padding: 1px;
            background: var(--gold-gradient);
            -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
            pointer-events: none;
            opacity: 0.2;
            transition: opacity 0.4s;
        }

        .gold-border:hover::before {
            opacity: 0.6;
        }

        /* ===== Typography ===== */
        .title {
            font-size: 22px;
            font-weight: 800;
            color: var(--text-primary);
        }

        .title-gold {
            color: var(--gold);
        }

        .subtitle {
            font-size: 13px;
            color: var(--text-secondary);
            font-weight: 500;
        }

        .label {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--text-muted);
        }

        .label-gold {
            color: var(--gold);
            letter-spacing: 2px;
        }

        .value {
            font-size: 28px;
            font-weight: 800;
            color: var(--text-primary);
        }

        .value-gold {
            color: var(--gold);
        }

        /* ===== Buttons ===== */
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            padding: 8px 16px;
            border-radius: var(--radius-sm);
            font-size: 11px;
            font-weight: 600;
            border: none;
            cursor: pointer;
            transition: all var(--transition);
            text-decoration: none;
            white-space: nowrap;
            background: transparent;
            color: var(--text-secondary);
            border: 1px solid var(--border-color);
        }

        .btn:hover {
            border-color: var(--gold);
            color: var(--gold);
            transform: translateY(-2px);
        }

        .btn-primary {
            background: var(--gold-gradient);
            color: #0d0d0d;
            border: none;
            font-weight: 700;
        }

        .btn-primary:hover {
            box-shadow: 0 4px 20px rgba(212, 175, 55, 0.3);
            transform: translateY(-2px);
            color: #0d0d0d;
        }

        .btn-icon {
            width: 34px;
            height: 34px;
            padding: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: var(--radius-sm);
            background: transparent;
            border: 1px solid var(--border-color);
            color: var(--text-muted);
            transition: all var(--transition);
            cursor: pointer;
        }

        .btn-icon:hover {
            border-color: var(--gold);
            color: var(--gold);
            background: rgba(212, 175, 55, 0.1);
        }

        .btn-donate {
            background: var(--gold-gradient);
            color: #0d0d0d;
            border: none;
            padding: 12px 32px;
            font-weight: 800;
            font-size: 15px;
            border-radius: var(--radius-sm);
            display: inline-flex;
            align-items: center;
            gap: 14px;
            text-decoration: none;
            transition: all 0.3s ease;
            cursor: pointer;
            animation: goldPulse 3s ease-in-out infinite;
        }

        .btn-donate:hover {
            transform: translateY(-3px) scale(1.03);
            box-shadow: 0 8px 40px rgba(212, 175, 55, 0.4);
        }

        @keyframes goldPulse {
            0%, 100% { box-shadow: 0 4px 20px rgba(212, 175, 55, 0.2); }
            50% { box-shadow: 0 4px 40px rgba(212, 175, 55, 0.4); }
        }

        /* ===== Input Group ===== */
        .input-group {
            display: flex;
            align-items: stretch;
            gap: 6px;
            background: var(--bg-input);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-sm);
            padding: 4px;
            transition: all var(--transition);
        }

        .input-group:focus-within {
            border-color: var(--gold);
            box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.15);
        }

        .input-group input {
            flex: 1;
            min-width: 0;
            padding: 10px 14px;
            background: transparent;
            border: none;
            color: var(--text-primary);
            font-size: 12px;
            font-family: 'Inter', monospace;
            outline: none;
        }

        .input-group input::selection {
            background: var(--gold);
            color: #0d0d0d;
        }

        /* ===== Format Items ===== */
        .format-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 14px;
            background: var(--bg-input);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-sm);
            transition: all var(--transition);
        }

        .format-item:hover {
            border-color: var(--gold);
            background: var(--bg-card-hover);
            transform: translateX(4px);
        }

        .format-tag {
            font-size: 9px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            padding: 4px 14px;
            border-radius: 4px;
            white-space: nowrap;
            flex-shrink: 0;
            min-width: 70px;
            text-align: center;
            border: 1px solid;
        }

        .format-tag-base64 {
            background: rgba(16, 185, 129, 0.15);
            color: #34d399;
            border-color: rgba(16, 185, 129, 0.3);
        }

        .format-tag-clash {
            background: rgba(139, 92, 246, 0.15);
            color: #a78bfa;
            border-color: rgba(139, 92, 246, 0.3);
        }

        .format-tag-singbox {
            background: rgba(245, 158, 11, 0.15);
            color: #fbbf24;
            border-color: rgba(245, 158, 11, 0.3);
        }

        .format-tag-raw {
            background: rgba(236, 72, 153, 0.15);
            color: #f472b6;
            border-color: rgba(236, 72, 153, 0.3);
        }

        .format-tag-shadowrocket {
            background: rgba(56, 189, 248, 0.15);
            color: #38bdf8;
            border-color: rgba(56, 189, 248, 0.3);
        }

        .format-input {
            flex: 1;
            min-width: 0;
            padding: 6px 10px;
            background: transparent;
            border: none;
            color: var(--text-primary);
            font-size: 11px;
            font-family: 'Inter', monospace;
            outline: none;
        }

        .format-input::selection {
            background: var(--gold);
            color: #0d0d0d;
        }

        .format-actions {
            display: flex;
            gap: 4px;
            flex-shrink: 0;
        }

        .btn-copy-small {
            padding: 4px 12px;
            font-size: 9px;
            border-radius: 4px;
            background: rgba(212, 175, 55, 0.15);
            color: var(--gold);
            border: 1px solid rgba(212, 175, 55, 0.2);
            cursor: pointer;
            transition: all var(--transition);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            white-space: nowrap;
        }

        .btn-copy-small:hover {
            background: var(--gold);
            color: #0d0d0d;
            transform: scale(1.05);
        }

        /* ===== Status Badge ===== */
        .badge {
            display: inline-block;
            padding: 4px 16px;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 600;
            border: 1px solid var(--border-color);
            background: transparent;
            color: var(--text-secondary);
        }

        .badge-active {
            background: rgba(16, 185, 129, 0.15);
            color: #34d399;
            border-color: rgba(16, 185, 129, 0.3);
        }

        .badge-paused {
            background: rgba(245, 158, 11, 0.15);
            color: #fbbf24;
            border-color: rgba(245, 158, 11, 0.3);
        }

        .badge-expired {
            background: rgba(239, 68, 68, 0.15);
            color: #f87171;
            border-color: rgba(239, 68, 68, 0.3);
        }

        /* ===== Progress ===== */
        .progress {
            height: 4px;
            border-radius: 4px;
            background: #2a2a2a;
            overflow: hidden;
            margin-top: 8px;
        }

        .progress-fill {
            height: 100%;
            border-radius: 4px;
            background: var(--gold-gradient);
            transition: width 0.8s ease;
        }

        /* ===== Avatar ===== */
        .avatar {
            width: 56px;
            height: 56px;
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(212, 175, 55, 0.15);
            border: 2px solid var(--gold);
            color: var(--gold);
            flex-shrink: 0;
        }

        .avatar svg {
            width: 28px;
            height: 28px;
        }

        /* ===== Grid ===== */
        .grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }

        .grid-4 {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 8px;
        }

        /* ===== Divider ===== */
        .divider-gold {
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--gold), transparent);
            margin: 16px 0;
            opacity: 0.3;
        }

        /* ===== Client Buttons ===== */
        .client-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 10px 14px;
            background: var(--bg-input);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-sm);
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            transition: all var(--transition);
            cursor: pointer;
        }

        .client-btn:hover {
            border-color: var(--gold);
            color: var(--gold);
            transform: translateY(-2px);
            box-shadow: 0 4px 16px rgba(212, 175, 55, 0.1);
        }

        .client-btn svg {
            width: 16px;
            height: 16px;
            flex-shrink: 0;
        }

        /* ===== Toast ===== */
        .toast {
            position: fixed;
            top: 24px;
            left: 50%;
            transform: translateX(-50%) translateY(-20px);
            background: var(--bg-card);
            border: 1px solid var(--gold);
            border-radius: var(--radius-sm);
            padding: 12px 24px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
            font-size: 13px;
            font-weight: 600;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 10px;
            z-index: 200;
            opacity: 0;
            pointer-events: none;
            transition: all 0.4s ease;
        }

        .toast.show {
            opacity: 1;
            transform: translateX(-50%) translateY(0);
            pointer-events: auto;
        }

        .toast-icon {
            color: var(--gold);
            flex-shrink: 0;
        }

        /* ===== Modal ===== */
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(8px);
            display: none;
            align-items: center;
            justify-content: center;
            padding: 24px;
            z-index: 100;
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .modal-overlay.show {
            display: flex;
            opacity: 1;
        }

        .modal-card {
            background: var(--bg-card);
            border: 1px solid var(--gold);
            border-radius: var(--radius);
            padding: 28px;
            max-width: 380px;
            width: 100%;
            transform: scale(0.95);
            transition: transform 0.3s ease;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
            position: relative;
        }

        .modal-overlay.show .modal-card {
            transform: scale(1);
        }

        .modal-close {
            position: absolute;
            top: 14px;
            right: 14px;
            background: none;
            border: none;
            color: var(--text-muted);
            cursor: pointer;
            padding: 4px;
            transition: all var(--transition);
        }

        .modal-close:hover {
            color: var(--text-primary);
        }

        /* ===== Responsive ===== */
        @media (max-width: 768px) {
            body { padding: 12px; }
            .card { padding: 16px 18px; }
            .grid-2 { grid-template-columns: 1fr; gap: 12px; }
            .grid-4 { grid-template-columns: repeat(2, 1fr); gap: 6px; }
            .value { font-size: 22px; }
            .title { font-size: 18px; }
            .avatar { width: 48px; height: 48px; }
            .avatar svg { width: 24px; height: 24px; }
            .format-item { flex-wrap: wrap; padding: 10px; }
            .format-tag { min-width: 60px; font-size: 8px; padding: 3px 10px; }
            .format-input { font-size: 10px; }
        }

        @media (max-width: 480px) {
            .grid-4 { grid-template-columns: 1fr 1fr; }
            .input-group input { font-size: 10px; padding: 6px 10px; }
            .btn { font-size: 10px; padding: 5px 12px; }
            .btn-donate { padding: 10px 20px; font-size: 13px; gap: 10px; }
            .format-item { gap: 6px; }
            .format-actions { width: 100%; justify-content: flex-end; }
        }

        /* ===== Utilities ===== */
        .flex { display: flex; }
        .flex-center { display: flex; align-items: center; justify-content: center; }
        .flex-between { display: flex; align-items: center; justify-content: space-between; }
        .gap-1 { gap: 6px; }
        .gap-2 { gap: 12px; }
        .gap-3 { gap: 16px; }
        .mt-1 { margin-top: 6px; }
        .mt-2 { margin-top: 12px; }
        .mt-3 { margin-top: 16px; }
        .mt-4 { margin-top: 24px; }
        .mb-1 { margin-bottom: 6px; }
        .mb-2 { margin-bottom: 12px; }
        .text-center { text-align: center; }
        .w-full { width: 100%; }
        .relative { position: relative; }

        /* ===== Animations ===== */
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .animate-in {
            animation: fadeInUp 0.5s ease forwards;
        }

        .delay-1 { animation-delay: 0.05s; opacity: 0; }
        .delay-2 { animation-delay: 0.1s; opacity: 0; }
        .delay-3 { animation-delay: 0.15s; opacity: 0; }
        .delay-4 { animation-delay: 0.2s; opacity: 0; }
        .delay-5 { animation-delay: 0.25s; opacity: 0; }
    </style>
</head>
<body>

    <!-- ===== Toast ===== -->
    <div id="toast" class="toast">
        <svg class="toast-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 6L9 17l-5-5"/>
        </svg>
        <span id="toast-msg">Copied!</span>
    </div>

    <!-- ===== Modal ===== -->
    <div id="qr-modal" class="modal-overlay">
        <div class="modal-card">
            <button class="modal-close" onclick="closeQR()">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18"/>
                    <line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
            </button>
            <h3 class="title text-center mb-2" id="qr-title" style="color: var(--gold);">SCAN QR</h3>
            <div class="flex-center">
                <img id="qr-img" src="" alt="QR Code" style="border-radius: 8px; background: white; padding: 8px; width: 200px; height: 200px;">
            </div>
            <p id="qr-text" class="text-center text-xs text-muted mt-3 break-all" style="font-family: monospace; font-size: 10px;"></p>
            <button onclick="closeQR()" class="btn btn-primary w-full mt-3">Close</button>
        </div>
    </div>

    <!-- ===== Main Container ===== -->
    <div class="container">

        <!-- ===== Header ===== -->
        <div class="card gold-border animate-in delay-1">
            <div class="flex-between">
                <div class="flex gap-2">
                    <div style="width: 40px; height: 40px; border-radius: var(--radius-sm); background: var(--gold-gradient); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0d0d0d" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                            <path d="M2 17l10 5 10-5"/>
                            <path d="M2 12l10 5 10-5"/>
                        </svg>
                    </div>
                    <div>
                        <div class="title"><span class="title-gold">✦</span> Panel</div>
                        <div class="subtitle">Subscription Manager</div>
                    </div>
                </div>
                <div class="flex gap-1">
                    <button onclick="copyAllLinks()" class="btn btn-primary" style="font-size: 10px; padding: 6px 14px;">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/>
                        </svg>
                        Copy All
                    </button>
                </div>
            </div>
        </div>

        <!-- ===== Profile ===== -->
        <div class="card gold-border animate-in delay-2">
            <div class="flex" style="gap: 16px; flex-wrap: wrap;">
                <div class="avatar">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                        <circle cx="12" cy="7" r="4"/>
                    </svg>
                </div>
                <div style="flex: 1; min-width: 140px;">
                    <div class="title" style="font-size: 18px;">__USER_NAME__</div>
                    <div class="subtitle" style="font-size: 12px; font-family: monospace;">ID: __USER_ID__</div>
                    <div class="flex gap-2 mt-1" style="flex-wrap: wrap;">
                        <span id="status-badge" class="badge badge-active">Active</span>
                        <span class="subtitle" style="font-size: 11px;">Expires: <strong style="color: var(--text-primary);">__EXPIRY_DATE__</strong></span>
                    </div>
                </div>
                <div style="text-align: right; flex-shrink: 0;">
                    <div class="label label-gold">IP</div>
                    <div class="subtitle" style="font-family: monospace; font-size: 13px;" id="client-ip">—</div>
                </div>
            </div>
        </div>

        <!-- ===== Stats ===== -->
        <div class="grid-2 animate-in delay-3">
            <div class="card gold-border">
                <div class="flex-between">
                    <span class="label label-gold">Total Usage</span>
                    <span class="subtitle" style="font-size: 11px;">/ __LIMIT_TOTAL_GB__ GB</span>
                </div>
                <div class="value value-gold mt-1">__TOTAL_GB__</div>
                __TOTAL_PROGRESS__
            </div>
            <div class="card gold-border">
                <div class="flex-between">
                    <span class="label label-gold">Daily Usage</span>
                    <span class="subtitle" style="font-size: 11px;">/ __LIMIT_DAILY_GB__ GB</span>
                </div>
                <div class="value value-gold mt-1">__DAILY_GB__</div>
                __DAILY_PROGRESS__
            </div>
        </div>

        <!-- ===== Subscription Links ===== -->
        <div class="card gold-border animate-in delay-4">
            <div class="flex-between mb-2">
                <div>
                    <div class="label label-gold">Subscription Links</div>
                    <div class="subtitle">Copy the link for your client</div>
                </div>
            </div>

            <div class="divider-gold"></div>

            <!-- Base64 -->
            <div class="format-item">
                <span class="format-tag format-tag-base64">Base64</span>
                <input type="text" class="format-input" id="link-base64" value="__SYNC_NORMAL__" readonly>
                <div class="format-actions">
                    <button onclick="copyLink('link-base64')" class="btn-copy-small">Copy</button>
                    <button onclick="showQR(document.getElementById('link-base64').value)" class="btn-icon" style="width: 30px; height: 30px;">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="3" width="7" height="7"/>
                            <rect x="14" y="3" width="7" height="7"/>
                            <rect x="3" y="14" width="7" height="7"/>
