        // =============================================
        // RENDER FUNCTIONS
        // =============================================
        function renderStats() {
            const stats = panelData.stats;
            const cards = document.querySelectorAll('.stat-card .value');
            if (cards.length >= 4) {
                cards[0].textContent = stats.totalUsers;
                cards[1].textContent = stats.activeUsers;
                cards[2].textContent = stats.todayUsage;
                cards[3].textContent = stats.totalUsage;
            }
        }

        function renderUsers() {
            const tbody = document.querySelector('tbody');
            if (!tbody) return;

            const statusMap = {
                active: { class: 'active', dot: 'on', text: 'فعال' },
                limited: { class: 'limited', dot: 'warn', text: 'محدود' },
                expired: { class: 'expired', dot: 'off', text: 'منقضی' },
                paused: { class: 'paused', dot: 'pause', text: 'متوقف' }
            };

            const users = panelData.users;

            tbody.innerHTML = users.map(user => {
                const status = statusMap[user.status] || statusMap.expired;
                const colorClass = user.percent > 80 ? 'amber' : user.percent > 50 ? 'purple' : 'green';
                const initial = user.name.charAt(0);
                const avatarColors = {
                    'س': 'rgba(129,140,248,0.15)',
                    'ر': 'rgba(251,191,36,0.15)',
                    'ع': 'rgba(248,113,113,0.15)',
                    'م': 'rgba(129,140,248,0.15)'
                };
                const avatarColor = avatarColors[initial] || 'rgba(129,140,248,0.15)';
                const textColor = initial === 'ر' ? 'var(--accent-amber)' : initial === 'ع' ? 'var(--accent-red)' :
                    'var(--accent-purple)';

                return `
                            <tr>
                                <td>
                                    <div style="display:flex;align-items:center;gap:10px;">
                                        <span class="user-avatar" style="background:${avatarColor};color:${textColor};">${initial}</span>
                                        <strong>${user.name}</strong>
                                    </div>
                                </td>
                                <td style="font-family: monospace; font-size: 12px; color: var(--text-muted);">${user.id}</td>
                                <td>
                                    <span>${user.usage}</span>
                                    <div class="usage-bar"><div class="fill ${colorClass}" style="width:${user.percent}%"></div></div>
                                </td>
                                <td>${user.quota}</td>
                                <td><span class="status-badge ${status.class}"><span class="status-dot ${status.dot}"></span> ${status.text}</span></td>
                                <td style="font-size: 12px; color: var(--text-muted);">${user.expiry}</td>
                                <td>
                                    <button class="btn btn-outline btn-sm">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <button class="btn btn-danger btn-sm">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        `;
            }).join('');

            // Update user count badge
            const badge = document.querySelector('.sidebar-item .badge');
            if (badge) badge.textContent = panelData.users.length;
        }

        function renderSystemStatus() {
            const sys = panelData.system;
            const statusItems = document.querySelectorAll('.status-item');
            if (statusItems.length >= 6) {
                // First item (server status)
                const dot = statusItems[0].querySelector('.indicator');
                if (dot) {
                    dot.className = 'indicator ' + (sys.status === 'online' ? 'online' : 'offline');
                }
                const value = statusItems[0].querySelector('.value');
                if (value) value.textContent = sys.status === 'online' ? 'آنلاین' : 'آفلاین';

                // CPU
                const cpuValue = statusItems[1].querySelector('.value');
                if (cpuValue) cpuValue.textContent = sys.cpu;

                // RAM
                const ramValue = statusItems[2].querySelector('.value');
                if (ramValue) ramValue.textContent = sys.ram;

                // Uptime
                const uptimeValue = statusItems[3].querySelector('.value');
                if (uptimeValue) uptimeValue.textContent = sys.uptime;

                // Core version
                const coreValue = statusItems[4].querySelector('.value');
                if (coreValue) coreValue.textContent = sys.coreVersion;
            }
        }

        // =============================================
        // INIT
        // =============================================
        document.addEventListener('DOMContentLoaded', function() {
            renderStats();
            renderUsers();
            renderSystemStatus();

            // Sidebar navigation
            document.querySelectorAll('.sidebar-item').forEach(item => {
                item.addEventListener('click', function(e) {
                    e.preventDefault();
                    document.querySelectorAll('.sidebar-item').forEach(i => i.classList.remove('active'));
                    this.classList.add('active');
                });
            });

            console.log('✅ Xray Panel loaded successfully');
            console.log('📊 Data:', panelData);
        });

        // =============================================
